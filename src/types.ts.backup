// Generates custom SQL dynamically based on configuration variables
export function getGeneratedSQL(config: {
  cancelMinutes: number;
  displacementTax: number;
  pointsPerBrl: number;
  enableRls: boolean;
}): string {
  return `-- ====================================================================
-- OTTO MOTOS - BANCO DE DADOS INICIAL DA INFRAESTRUTURA (SUPABASE POSTGRESQL)
-- Gerado dinamicamente para o portal de Engenharia OttoMotos
-- Data de Criação: 2026-06-09 | Autor: Core Software Architect
-- ====================================================================

-- --------------------------------------------------------------------
-- 0. EXTENSÕES & ENUMS
-- --------------------------------------------------------------------
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Define o tipo de modelo de serviço/atendimento
CREATE TYPE service_model AS ENUM ('Express', 'Station', 'Mobile');

-- Define o tipo de agendamento do catálogo
CREATE TYPE service_schedule_type AS ENUM ('Pronto Atendimento', 'Sob Agendamento');

-- Define o nível de permissão do usuário
CREATE TYPE user_role AS ENUM ('client_b2c', 'client_b2b', 'mechanic', 'admin');

-- Define o status da ordem de serviço
CREATE TYPE order_status AS ENUM ('PENDING', 'IN_PROGRESS', 'COMPLETED', 'CANCELLED');

-- --------------------------------------------------------------------
-- 1. TABELA: users_profiles (Perfis de Usuários Integrados ao Supabase Auth)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.users_profiles (
    id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    phone VARCHAR(50),
    role user_role NOT NULL DEFAULT 'client_b2c',
    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()
);

COMMENT ON TABLE public.users_profiles IS 'Dados estendidos de perfil integrados ao Supabase Auth.';

-- --------------------------------------------------------------------
-- 2. TABELA: services_catalog (Catálogo Simplificado de Serviços)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.services_catalog (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) UNIQUE NOT NULL,
    type service_schedule_type NOT NULL DEFAULT 'Pronto Atendimento',
    estimated_time_m INT NOT NULL, -- tempo estipulado em minutos
    base_price_brl NUMERIC(10, 2) NOT NULL DEFAULT 0.00,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Carga inicial requerida pela startup
INSERT INTO public.services_catalog (name, type, estimated_time_m, base_price_brl)
VALUES 
('TROCAR ÓLEO DE MOTOR', 'Pronto Atendimento', 20, 55.00),
('TROCA DA PASTILHA DE FREIO', 'Pronto Atendimento', 20, 45.00),
('TROCAR KIT TRANSMISSÃO', 'Sob Agendamento', 30, 180.00)
ON CONFLICT (name) DO UPDATE 
SET type = EXCLUDED.type, estimated_time_m = EXCLUDED.estimated_time_m, base_price_brl = EXCLUDED.base_price_brl;

-- --------------------------------------------------------------------
-- 3. TABELA: service_orders (Gestão de Ordens de Serviço com Auditoria de Horário)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.service_orders (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    client_id UUID NOT NULL REFERENCES public.users_profiles(id),
    mechanic_id UUID REFERENCES public.users_profiles(id),
    vehicle_plate VARCHAR(12) NOT NULL,
    vehicle_model VARCHAR(100) NOT NULL,
    start_time TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
    end_time TIMESTAMP WITH TIME ZONE,
    attendance_model service_model NOT NULL DEFAULT 'Express',
    status order_status NOT NULL DEFAULT 'PENDING',
    displacement_tax NUMERIC(10, 2) NOT NULL DEFAULT 0.00,
    ai_diagnostics JSONB DEFAULT '{}'::jsonb, -- Análises geradas posteriormente pelo Gemini AI
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexação para busca rápida de placas e filtros de status
CREATE INDEX IF NOT EXISTS idx_so_vehicle_plate ON public.service_orders(vehicle_plate);
CREATE INDEX IF NOT EXISTS idx_so_status ON public.service_orders(status);
CREATE INDEX IF NOT EXISTS idx_so_client ON public.service_orders(client_id);

-- --------------------------------------------------------------------
-- 4. TABELA: inventory (Gestão de Estoque OttoMotos)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.inventory (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    item_name VARCHAR(255) UNIQUE NOT NULL,
    quantity INT NOT NULL DEFAULT 0,
    minimum_threshold INT NOT NULL DEFAULT 5,
    last_restock TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Tabela para alertas de estoque gerados por trigger (Auditoria/Notificações)
CREATE TABLE IF NOT EXISTS public.inventory_alerts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    inventory_id UUID REFERENCES public.inventory(id) ON DELETE CASCADE,
    item_name VARCHAR(255) NOT NULL,
    current_quantity INT NOT NULL,
    minimum_threshold INT NOT NULL,
    alert_triggered_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- --------------------------------------------------------------------
-- 5. TABELA: loyalty_program (Programa de Geração de Pontos e Benefícios)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.loyalty_program (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    client_id UUID UNIQUE NOT NULL REFERENCES public.users_profiles(id) ON DELETE CASCADE,
    points_balance INT NOT NULL DEFAULT 0,
    has_reserve_bike_access BOOLEAN NOT NULL DEFAULT FALSE,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- --------------------------------------------------------------------
-- 6. TABELA: checklist_validations (Gestão de Storage & Validação Visual com Gemini AI)
-- --------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.checklist_validations (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    service_order_id UUID NOT NULL REFERENCES public.service_orders(id) ON DELETE CASCADE,
    uploaded_image_url VARCHAR(1024) NOT NULL, -- Caminho do Bucket "checklist_images"
    part_name VARCHAR(255) NOT NULL, -- Peça informada (Ex: "Pastilha de freio")
    pre_existing_damage TEXT, -- Observação do mecânico
    gemini_validation_response JSONB DEFAULT '{}'::jsonb, -- Retorno estruturado do Gemini Vision
    validated BOOLEAN NOT NULL DEFAULT FALSE, -- Identifica se o Gemini confirmou a peça correspondente
    checked_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- ====================================================================
-- TRIGGERS E FUNÇÕES (REGRAS DE NEGÓCIO CRÍTICAS NO BANCO)
-- ====================================================================

-- --------------------------------------------------------------------
-- REGRA 1: Taxa de Deslocamento no Cancelamento após ${config.cancelMinutes} Minutos
-- --------------------------------------------------------------------
CREATE OR REPLACE FUNCTION public.fn_process_order_cancellation()
RETURNS TRIGGER AS $$
DECLARE
    elapsed_minutes INT;
BEGIN
    -- Verifica se o status mudou para CANCELLED
    IF NEW.status = 'CANCELLED' AND OLD.status <> 'CANCELLED' THEN
        -- Calcula os minutos decorridos entre start_time de atendimento e agora
        elapsed_minutes := EXTRACT(EPOCH FROM (NOW() - NEW.start_time)) / 60;
        
        -- Se o cancelamento ocorrer após os ${config.cancelMinutes} minutos grátis
        IF elapsed_minutes > ${config.cancelMinutes} THEN
            -- Aplica a taxa padrão de deslocamento
            NEW.displacement_tax := ${config.displacementTax}.00;
        ELSE
            NEW.displacement_tax := 0.00;
        END IF;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trg_order_cancellation
BEFORE UPDATE ON public.service_orders
FOR EACH ROW
EXECUTE FUNCTION public.fn_process_order_cancellation();


-- --------------------------------------------------------------------
-- REGRA 2: Alerta Automático de Estoque Mínimo (Trigger do Inventário)
-- --------------------------------------------------------------------
CREATE OR REPLACE FUNCTION public.fn_check_inventory_threshold()
RETURNS TRIGGER AS $$
BEGIN
    -- Se a quantidade caiu e atingiu ou ficou abaixo do limite mínimo
    IF NEW.quantity <= NEW.minimum_threshold AND (OLD.quantity IS NULL OR OLD.quantity > NEW.minimum_threshold) THEN
        -- Registra um alerta na tabela de notificações de estoque
        INSERT INTO public.inventory_alerts (inventory_id, item_name, current_quantity, minimum_threshold)
        VALUES (NEW.id, NEW.item_name, NEW.quantity, NEW.minimum_threshold);
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trg_inventory_low_alert
AFTER UPDATE OR INSERT ON public.inventory
FOR EACH ROW
EXECUTE FUNCTION public.fn_check_inventory_threshold();


-- --------------------------------------------------------------------
-- BONUS REGRA 3: Geração automática de Perfis no Supabase SignUp
-- --------------------------------------------------------------------
CREATE OR REPLACE FUNCTION public.handle_new_user_registration()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO public.users_profiles (id, name, email, role)
  VALUES (
    NEW.id,
    COALESCE(NEW.raw_user_meta_data->>'name', 'Usuário OttoMotos'),
    NEW.email,
    COALESCE((NEW.raw_user_meta_data->>'role')::user_role, 'client_b2c'::user_role)
  );

  -- Cria também o registro opcional do programa de fidelidade do cliente
  IF NEW.raw_user_meta_data->>'role' IS NULL OR NEW.raw_user_meta_data->>'role' IN ('client_b2c', 'client_b2b') THEN
    INSERT INTO public.loyalty_program (client_id, points_balance, has_reserve_bike_access)
    VALUES (NEW.id, 0, FALSE);
  END IF;

  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trg_on_auth_signup
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user_registration();


-- ====================================================================
-- CONFIGURAÇÃO DE SEGURANÇA: ROW LEVEL SECURITY (RLS)
-- ====================================================================

${config.enableRls ? `ALTER TABLE public.users_profiles ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.services_catalog ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.service_orders ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.inventory ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.inventory_alerts ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.loyalty_program ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.checklist_validations ENABLE ROW LEVEL SECURITY;

-- POLICIES: users_profiles
CREATE POLICY "Qualquer pessoa autenticada visualiza perfis" 
ON public.users_profiles FOR SELECT TO authenticated USING (true);

CREATE POLICY "Usuários editam apenas o próprio perfil" 
ON public.users_profiles FOR UPDATE TO authenticated USING (auth.uid() = id);

-- POLICIES: services_catalog (Lido por todos, alterado apenas por administradores)
CREATE POLICY "Qualquer nível acessa catálogo" 
ON public.services_catalog FOR SELECT USING (true);

CREATE POLICY "Administradores gerenciam catálogo" 
ON public.services_catalog FOR ALL TO authenticated 
USING (EXISTS (SELECT 1 FROM public.users_profiles WHERE id = auth.uid() AND role = 'admin'));

-- POLICIES: service_orders (Filtro por papel do cliente B2C/B2B e mecânico)
CREATE POLICY "Clientes visualizam as próprias OS" 
ON public.service_orders FOR SELECT TO authenticated 
USING (client_id = auth.uid() OR mechanic_id = auth.uid() OR EXISTS (
    SELECT 1 FROM public.users_profiles WHERE id = auth.uid() AND role IN ('admin', 'mechanic')
));

CREATE POLICY "Mecânicos e Admins inserem/editam ordens de serviço" 
ON public.service_orders FOR ALL TO authenticated 
USING (EXISTS (
    SELECT 1 FROM public.users_profiles WHERE id = auth.uid() AND role IN ('admin', 'mechanic')
));

-- POLICIES: inventory & alerts (Mecânicos e Admins)
CREATE POLICY "Mecânicos e Admins monitoram estoque" 
ON public.inventory FOR SELECT TO authenticated USING (true);

CREATE POLICY "Apenas Admins atualizam estoque" 
ON public.inventory FOR ALL TO authenticated 
USING (EXISTS (SELECT 1 FROM public.users_profiles WHERE id = auth.uid() AND role = 'admin'));` : `-- RLS Desabilitado temporariamente para desenvolvimento rápido`}

-- --------------------------------------------------------------------
-- BUCKETS DE STORAGE (CONFIGURAÇÃO NO SUPABASE STORAGE)
-- --------------------------------------------------------------------
-- NOTA: O Supabase Storage exige inserções na tabela storage.buckets pelo painel ou DDL de sistema:
-- INSERT INTO storage.buckets (id, name, public) VALUES ('checklist_images', 'checklist_images', true);
--
-- Exemplo de Política do Storage correspondente:
-- CREATE POLICY "Apenas mecânicos e admins fazem upload para o bucket"
-- ON storage.objects FOR INSERT TO authenticated
-- WITH CHECK (bucket_id = 'checklist_images' AND EXISTS (
--    SELECT 1 FROM public.users_profiles WHERE id = auth.uid() AND role IN ('mechanic', 'admin')
-- ));
`;
}

