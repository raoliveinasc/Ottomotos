/**
 * Types and static setup scripts for OttoMotos Developer Portal & Database Modeler.
 */

export interface UserProfile {
  id: string; // Auth UUID
  name: string;
  email: string;
  phone: string;
  role: 'client_b2c' | 'client_b2b' | 'mechanic' | 'admin';
  created_at: string;
}

export interface ServiceItem {
  id: string;
  name: string;
  type: 'Pronto Atendimento' | 'Sob Agendamento';
  estimated_time_m: number; // in minutes
  base_price_brl: number;
}

export interface ServiceOrder {
  id: string;
  client_id: string;
  mechanic_id: string;
  vehicle_plate: string;
  vehicle_model: string;
  start_time: string;
  end_time: string | null;
  attendance_model: 'Express' | 'Station' | 'Mobile';
  status: 'PENDING' | 'IN_PROGRESS' | 'COMPLETED' | 'CANCELLED' | 'REMOVAL';
  displacement_tax: number;
  ai_diagnostics: {
    pred_maintenance?: string;
    anomaly_alerts?: string[];
    risk_level?: 'LOW' | 'MEDIUM' | 'HIGH';
    engine_temp_analysis?: string;
    gemini_summary?: string;
  } | null;
  created_at: string;
  cancellation_time?: string;
  rating?: number;
  feedback?: string;
  total_spent?: number;
  rework_required?: boolean;
}

export interface InventoryItem {
  id: string;
  item_name: string;
  quantity: number;
  minimum_threshold: number;
  alert_active: boolean;
}

export interface StockMovement {
  id: string;
  item_id: string;
  item_name: string;
  type: 'ENTRY' | 'EXIT' | 'RETURN';
  quantity: number;
  reason: string;
  timestamp: string;
  service_order_id?: string;
}

export interface LoyaltyProfile {
  id: string;
  client_id: string;
  points_balance: number;
  has_reserve_bike_access: boolean;
}

export interface ChecklistValidation {
  id: string;
  service_order_id: string;
  uploaded_image_url: string; // reference to Supabase checklist_images bucket path
  part_name: string;
  pre_existing_damage: string; // "Banco rasgado", "Escapamento ralado", etc.
  gemini_validation_response: {
    part_recognized: string;
    is_correct_part_for_order: boolean;
    confidence_score: number;
    visual_anomalies_detected: string[];
    gemini_safety_rating: 'SAFE' | 'WARN' | 'DANGER';
  } | null;
  validated: boolean;
  checked_at: string;
}

