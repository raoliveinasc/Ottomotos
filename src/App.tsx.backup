import { useState, useEffect } from 'react';
import {
  Database,
  Terminal,
  Code,
  Cpu,
  ShieldCheck,
  AlertTriangle,
  ArrowRight,
  CheckCircle,
  RefreshCw,
  Upload,
  Copy,
  Play,
  Check,
  GitBranch,
  ChevronRight,
  X,
  Sparkles,
  Award,
  CircleAlert,
  Sliders,
  Settings,
  Flame,
  FileCode,
  ListFilter,
  Smartphone,
  Globe,
  Video,
  Calendar,
  Truck,
  Eye,
  Users,
  Clock,
  Camera,
  TrendingUp,
  BarChart3,
  PieChart,
  ShoppingBag,
  History,
  DollarSign,
  ClipboardCheck
} from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import {
  UserProfile,
  ServiceItem,
  ServiceOrder,
  InventoryItem,
  StockMovement,
  LoyaltyProfile,
  ChecklistValidation,
  INITIAL_USERS,
  INITIAL_SERVICES,
  INITIAL_INVENTORY,
  INITIAL_LOYALTY,
  INITIAL_ORDERS,
  INITIAL_VALIDATIONS,
  getGeneratedSQL,
  GITHUB_AND_VERCEL_STEPS,
  ENV_EXAMPLE_FILE_CONTENT
} from './types';
import RoutingMap from './components/RoutingMap';

export default function App() {
  // Google Maps Routing State
  const [routeDistance, setRouteDistance] = useState<string>('2.4 km');
  const [routeDuration, setRouteDuration] = useState<string>('12 min');

  // Config parameters for Dynamic SQL Generator
  const [cancelMinutes, setCancelMinutes] = useState<number>(30);
  const [displacementTax, setDisplacementTax] = useState<number>(50);
  const [enableRls, setEnableRls] = useState<boolean>(true);

  // Simulated Database State
  const [users, setUsers] = useState<UserProfile[]>(INITIAL_USERS);
  const [services, setServices] = useState<ServiceItem[]>(INITIAL_SERVICES);
  const [orders, setOrders] = useState<ServiceOrder[]>(INITIAL_ORDERS);
  const [inventory, setInventory] = useState<InventoryItem[]>(INITIAL_INVENTORY);
  const [loyalty, setLoyalty] = useState<LoyaltyProfile[]>(INITIAL_LOYALTY);
  const [validations, setValidations] = useState<ChecklistValidation[]>(INITIAL_VALIDATIONS);

  // Simulation Alert Logs
  const [alertLogs, setAlertLogs] = useState<Array<{ id: string; msg: string; time: string; type: 'warning' | 'success' | 'info' }>>([
    { id: '1', msg: 'Sistema inicializado: Banco de Dados Simulado Carregado.', time: '02:49:01', type: 'info' }
  ]);

  // Selected Active Tab in main navigation
  const [currentTab, setCurrentTab] = useState<'landing' | 'sql' | 'env' | 'git' | 'simulator' | 'web-mobile' | 'backoffice'>('landing');
  const [viewMode, setViewMode] = useState<'desktop' | 'mobile'>('desktop');
  const [simSubTab, setSimSubTab] = useState<'cancellation' | 'inventory' | 'gemini' | 'loyalty'>('cancellation');
  const [activeModel, setActiveModel] = useState<'station' | 'mobile' | 'express'>('mobile');
  const [activeFaq, setActiveFaq] = useState<number | null>(null);

  // Back-office & Gestão de Estoque States
  const [stockMovements, setStockMovements] = useState<StockMovement[]>([
    { id: 'mov-1', item_id: 'inv-1', item_name: 'Óleo Motor Mobil Super Moto 10W30', type: 'ENTRY', quantity: 24, reason: 'Entrada de estoque inicial para furgões', timestamp: '2026-06-08T08:00:00Z' },
    { id: 'mov-2', item_id: 'inv-2', item_name: 'Pastilha de Freio Traseira Cobreq (CG150/160)', type: 'ENTRY', quantity: 15, reason: 'Entrada de lote semanal', timestamp: '2026-06-08T08:15:00Z' },
    { id: 'mov-3', item_id: 'inv-3', item_name: 'Kit de Transmissão Completo Riffel (Bros 160)', type: 'ENTRY', quantity: 5, reason: 'Lote inicial do fornecedor', timestamp: '2026-06-08T08:20:00Z' },
    { id: 'mov-4', item_id: 'inv-3', item_name: 'Kit de Transmissão Completo Riffel (Bros 160)', type: 'EXIT', quantity: 2, reason: 'Consumido no reparo da O.S. #981', timestamp: '2026-06-08T14:30:00Z', service_order_id: 'os-981' },
    { id: 'mov-5', item_id: 'inv-4', item_name: 'Filtro de Ar de Alta Performance (Fazer 250)', type: 'ENTRY', quantity: 4, reason: 'Entrada de lote reserva', timestamp: '2026-06-08T09:00:00Z' },
    { id: 'mov-6', item_id: 'inv-4', item_name: 'Filtro de Ar de Alta Performance (Fazer 250)', type: 'EXIT', quantity: 2, reason: 'Consumido no reparo da O.S. #982', timestamp: '2026-06-08T16:45:00Z', service_order_id: 'os-982' },
    { id: 'mov-7', item_id: 'inv-2', item_name: 'Pastilha de Freio Traseira Cobreq (CG150/160)', type: 'RETURN', quantity: 1, reason: 'Cancelamento de agendamento O.S. #990 (peça devolvida intacta)', timestamp: '2026-06-09T09:00:00Z' }
  ]);

  const [newMovementItem, setNewMovementItem] = useState<string>('inv-1');
  const [newMovementType, setNewMovementType] = useState<'ENTRY' | 'EXIT' | 'RETURN'>('ENTRY');
  const [newMovementQty, setNewMovementQty] = useState<number>(5);
  const [newMovementReason, setNewMovementReason] = useState<string>('');

  // Copy States
  const [copiedSQL, setCopiedSQL] = useState<boolean>(false);
  const [copiedEnv, setCopiedEnv] = useState<boolean>(false);
  const [copiedCodeIndex, setCopiedCodeIndex] = useState<number | null>(null);

  // Cancellation Simulator States
  const [selectedOSId, setSelectedOSId] = useState<string>('os-1002');
  const [cancellationTimeOffset, setCancellationTimeOffset] = useState<number>(15); // elapsed minutes

  // Gemini Simulator States
  const [geminiStatus, setGeminiStatus] = useState<'idle' | 'scanning' | 'done'>('idle');
  const [inspectionPart, setInspectionPart] = useState<string>('Pastilha de Freio Traseira');
  const [damagePreset, setDamagePreset] = useState<string>('Fricção metálica severa, restando apenas 1.5mm de composto de frenagem');
  const [uploadedImagePreset, setUploadedImagePreset] = useState<string>('https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&q=80&w=400');
  const [geminiResult, setGeminiResult] = useState<any>(null);

  // Loyalty Add Score state
  const [loyaltyTargetUser, setLoyaltyTargetUser] = useState<string>('usr-client-1');
  const [loyaltyPointsToAdd, setLoyaltyPointsToAdd] = useState<number>(100);

  // Web-to-Mobile simulation states
  const [mobileScreen, setMobileScreen] = useState<'mechanic' | 'client' | 'b2b'>('client');
  const [mobilePhotoStatus, setMobilePhotoStatus] = useState<'idle' | 'taking' | 'processing' | 'done'>('idle');
  const [mobileLoyaltyAdded, setMobileLoyaltyAdded] = useState<boolean>(false);
  const [cameraOpen, setCameraOpen] = useState<boolean>(false);
  
  // Tablet do Mecânico (Van) - Padronização, Controle de Tempo & Auditoria Visual
  const [mechActiveOSId, setMechActiveOSId] = useState<string>('os-1002');
  const [mechSubTab, setMechSubTab] = useState<'pre' | 'post' | 'removal'>('pre');
  const [mechChecklists, setMechChecklists] = useState<Record<string, {
    pre_damages: string[];
    pre_notes: string;
    pre_photo: string | null;
    pre_photo_status: 'idle' | 'taking' | 'processing' | 'done';
    pre_completed: boolean;
    
    post_items: Record<string, boolean>;
    post_completed: boolean;
    
    removal_reason: string;
    is_removal_triggered: boolean;
    removal_confirmed: boolean;
    
    timer_seconds: number;
    timer_active: boolean;
    timer_done: boolean;
  }>>({
    'os-1002': {
      pre_damages: [],
      pre_notes: '',
      pre_photo: null,
      pre_photo_status: 'idle',
      pre_completed: false,
      post_items: {
        'calibragem': false,
        'setas': false,
        'partida': false,
        'buzina': false,
        'freio_dianteiro': false,
        'freio_traseiro': false,
        'nivel_oleo': false,
        'suspensao': false,
        'aperto_guidao': false,
        'lubrificacao': false
      },
      post_completed: false,
      removal_reason: '',
      is_removal_triggered: false,
      removal_confirmed: false,
      timer_seconds: 0,
      timer_active: false,
      timer_done: false
    },
    'os-1001': {
      pre_damages: ['Banco Rasgado'],
      pre_notes: 'Fissura superficial no assento.',
      pre_photo: 'https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&q=80&w=200',
      pre_photo_status: 'done',
      pre_completed: true,
      post_items: {
        'calibragem': true,
        'setas': true,
        'partida': true,
        'buzina': true,
        'freio_dianteiro': true,
        'freio_traseiro': true,
        'nivel_oleo': true,
        'suspensao': true,
        'aperto_guidao': true,
        'lubrificacao': true
      },
      post_completed: true,
      removal_reason: '',
      is_removal_triggered: false,
      removal_confirmed: false,
      timer_seconds: 642,
      timer_active: false,
      timer_done: true
    }
  });

  // Safe setInterval based Live Stopwatch
  useEffect(() => {
    const interval = setInterval(() => {
      setMechChecklists(prev => {
        let changed = false;
        const updated = { ...prev };
        Object.keys(updated).forEach(osId => {
          const item = updated[osId];
          if (item && item.timer_active) {
            updated[osId] = {
              ...item,
              timer_seconds: item.timer_seconds + 1
            };
            changed = true;
          }
        });
        return changed ? updated : prev;
      });
    }, 1000);
    return () => clearInterval(interval);
  }, []);

  const getMechChecklist = (osId: string) => {
    if (!mechChecklists[osId]) {
      return {
        pre_damages: [],
        pre_notes: '',
        pre_photo: null,
        pre_photo_status: 'idle',
        pre_completed: false,
        post_items: {
          'calibragem': false,
          'setas': false,
          'partida': false,
          'buzina': false,
          'freio_dianteiro': false,
          'freio_traseiro': false,
          'nivel_oleo': false,
          'suspensao': false,
          'aperto_guidao': false,
          'lubrificacao': false
        },
        post_completed: false,
        removal_reason: '',
        is_removal_triggered: false,
        removal_confirmed: false,
        timer_seconds: 0,
        timer_active: false,
        timer_done: false
      };
    }
    return mechChecklists[osId];
  };

  // Client app simulation sub-tabs & budget states
  const [clientSubTab, setClientSubTab] = useState<'tracking' | 'schedule' | 'rewards'>('tracking');
  const [selectedServices, setSelectedServices] = useState<string[]>(['srv-1', 'srv-2']);
  const [attendanceType, setAttendanceType] = useState<'base' | 'van'>('van');
  const [cameraViewActive, setCameraViewActive] = useState<boolean>(true);
  const [cameraFeedId, setCameraFeedId] = useState<string>('bay-3');
  
  // B2B Frotistas fleet state
  const [fleetBikes, setFleetBikes] = useState([
    { id: 'f1', model: 'Honda CG 160 Cargo', plate: 'FRO-1001', status: 'Troca de Óleo', progress: 65, bay: 'Baia #1', mechanic: 'Danilo', camActive: true },
    { id: 'f2', model: 'Honda Biz 125', plate: 'FRO-1002', status: 'Aguardando Lavagem', progress: 15, bay: 'Baia #3', mechanic: 'Marcos', camActive: true },
    { id: 'f3', model: 'Yamaha YBR 150', plate: 'FRO-1003', status: 'Inspeção de Freio', progress: 45, bay: 'Baia #2', mechanic: 'Felipe', camActive: true },
    { id: 'f4', model: 'Honda CG 160 Fan', plate: 'FRO-1004', status: 'Pronta / Disponível', progress: 100, bay: 'Lavagem', mechanic: 'Danilo', camActive: false },
  ]);
  const [selectedB2bBikeId, setSelectedB2bBikeId] = useState<string>('f1');
  const [isB2bCamOpen, setIsB2bCamOpen] = useState<boolean>(false);

  // GitHub integration states
  const [gitUser, setGitUser] = useState<string>('RAIFRAN-DESENVOLVEDOR-PORTFOLIO');
  const [gitRepo, setGitRepo] = useState<string>('ottomotos');
  const [gitBranch, setGitBranch] = useState<string>('main');
  const [gitSyncStatus, setGitSyncStatus] = useState<'idle' | 'linking' | 'pushing' | 'synced'>('idle');
  const [gitTerminalLogs, setGitTerminalLogs] = useState<string[]>([]);

  // Add Log helper
  const addLog = (msg: string, type: 'warning' | 'success' | 'info' = 'info') => {
    const now = new Date();
    const timeStr = now.toTimeString().split(' ')[0];
    setAlertLogs(prev => [
      { id: `${Date.now()}-${Math.random()}`, msg, time: timeStr, type },
      ...prev
    ]);
  };

  // GitHub terminal simulation trigger
  const startGitSimulation = () => {
    if (gitSyncStatus !== 'idle') return;
    setGitSyncStatus('linking');
    setGitTerminalLogs([
      `$ git init`,
      `Initialized empty Git repository in /workspace/${gitRepo}-frontend/.git/`,
      `$ git add .`,
      `$ git commit -m "feat: initial setup, supabase database schema and folder structure"`,
      `[main (root-commit) a1b2c3d] feat: initial setup, supabase database schema and folder structure`,
      ` 12 files changed, 258 insertions(+)`,
      ` create mode 100644 package.json`,
      ` create mode 100644 src/app/page.tsx`,
      `$ git branch -M ${gitBranch}`
    ]);

    setTimeout(() => {
      setGitSyncStatus('pushing');
      setGitTerminalLogs(prev => [
        ...prev,
        `$ git remote add origin https://github.com/${gitUser}/${gitRepo}.git`,
        `$ git push -u origin ${gitBranch}`,
        `Enumerating objects: 15, done.`,
        `Counting objects: 100% (15/15), done.`,
        `Delta compression using up to 8 threads`,
        `Compressing objects: 100% (12/12), done.`,
        `Writing objects: 100% (15/15), 3.42 KiB | 3.42 MiB/s, done.`,
        `Total 15 (delta 1), reused 0 (delta 0), pack-reused 0`
      ]);

      setTimeout(() => {
        setGitSyncStatus('synced');
        setGitTerminalLogs(prev => [
          ...prev,
          `To https://github.com/${gitUser}/${gitRepo}.git`,
          ` * [new branch]      ${gitBranch} -> ${gitBranch}`,
          `branch '${gitBranch}' set up to track remote branch '${gitBranch}' from 'origin'.`,
          `Sincronização com o repositório GitHub concluída com sucesso! 🎉`
        ]);
        addLog(`GitHub: Repositório github.com/${gitUser}/${gitRepo} sincronizado com sucesso via HTTPS.`, 'success');
      }, 1500);
    }, 1500);
  };

  // Trigger Cancel simulation matching the postgres trigger logic perfectly
  const executeCancellationTrigger = (osId: string, elapsedMin: number) => {
    const order = orders.find(o => o.id === osId);
    if (!order) {
      addLog('Ordem de serviço não encontrada', 'warning');
      return;
    }
    if (order.status === 'CANCELLED') {
      addLog(`O.S. ${osId} já se encontra CANCELADA.`, 'warning');
      return;
    }

    const start = new Date();
    // Simulate creation time by subtracting minutes
    start.setMinutes(start.getMinutes() - elapsedMin);

    let tax = 0;
    let message = '';
    
    // Simulate Trigger Logic:
    // elapsed_minutes = EXTRACT(EPOCH FROM (NOW() - NEW.start_time)) / 60;
    // IF elapsed_minutes > cancelMinutes THEN NEW.displacement_tax := displacementTax; ELSE NEW.displacement_tax := 0;
    if (elapsedMin > cancelMinutes) {
      tax = displacementTax;
      message = `TRIGGER SQL trg_order_cancellation: Cancelamento da O.S. ${osId} após o limite grátis (${elapsedMin}min Decorridos). Taxa de deslocamento de R$ ${displacementTax},00 aplicada com sucesso!`;
      addLog(message, 'warning');
    } else {
      tax = 0;
      message = `TRIGGER SQL trg_order_cancellation: Cancelamento efetuado dentro do prazo de tolerância (${elapsedMin}min / ${cancelMinutes}min limite). Isento de taxa!`;
      addLog(message, 'success');
    }

    setOrders(prev => prev.map(o => {
      if (o.id === osId) {
        return {
          ...o,
          status: 'CANCELLED',
          displacement_tax: tax,
          cancellation_time: new Date().toISOString()
        };
      }
      return o;
    }));
  };

  // Trigger inventory decrease/increase simulation with alert trigger checks
  const handleInventoryQuantityChange = (itemId: string, delta: number) => {
    setInventory(prev => prev.map(item => {
      if (item.id === itemId) {
        const newQty = Math.max(0, item.quantity + delta);
        const threshold = item.minimum_threshold;
        
        let shouldTriggerAlert = false;
        // Trigger condition: quantity falls below or equal minimum_threshold, and previous quantity was above it.
        if (newQty <= threshold && item.quantity > threshold) {
          shouldTriggerAlert = true;
        }

        if (shouldTriggerAlert) {
          const alertMsg = `TRIGGER SQL trg_inventory_low_alert: Alerta crítico! Estoque de [${item.item_name}] atingiu nível mínimo (${newQty} no estoque / Mínimo: ${threshold}). Registrado em inventory_alerts.`;
          addLog(alertMsg, 'warning');
          return { ...item, quantity: newQty, alert_active: true };
        } else {
          return { ...item, quantity: newQty, alert_active: newQty <= threshold };
        }
      }
      return item;
    }));
  };

  const handleAddStockMovement = (itemId: string, type: 'ENTRY' | 'EXIT' | 'RETURN', qty: number, reason: string) => {
    if (qty <= 0) {
      addLog('Erro: A quantidade de movimentação deve ser maior que zero.', 'warning');
      return;
    }
    
    let targetItemName = '';
    let success = false;
    
    setInventory(prev => prev.map(item => {
      if (item.id === itemId) {
        targetItemName = item.item_name;
        let newQty = item.quantity;
        
        if (type === 'ENTRY' || type === 'RETURN') {
          newQty = item.quantity + qty;
        } else if (type === 'EXIT') {
          if (item.quantity < qty) {
            addLog(`Erro de Estoque: Estoque insuficiente de ${item.item_name}. Disponível: ${item.quantity}, Requerido: ${qty}`, 'warning');
            return item;
          }
          newQty = item.quantity - qty;
        }
        
        success = true;
        const threshold = item.minimum_threshold;
        const alert_active = newQty <= threshold;
        
        if (alert_active && !item.alert_active) {
          const alertMsg = `TRIGGER SQL trg_inventory_low_alert: Alerta crítico! Estoque de [${item.item_name}] atingiu nível mínimo de segurança (${newQty} no estoque / Mínimo: ${threshold}). Registrado em inventory_alerts.`;
          addLog(alertMsg, 'warning');
        } else if (!alert_active && item.alert_active) {
          addLog(`Gatilho SQL: Estoque de [${item.item_name}] restabelecido para ${newQty} unidades (acima do limite mínimo de ${threshold}). Alerta normalizado em inventory_alerts.`, 'success');
        }
        
        return { ...item, quantity: newQty, alert_active };
      }
      return item;
    }));
    
    if (success) {
      const newMov: StockMovement = {
        id: `mov-${Date.now()}`,
        item_id: itemId,
        item_name: targetItemName || 'Item Desconhecido',
        type,
        quantity: qty,
        reason: reason || (type === 'ENTRY' ? 'Reabastecimento manual' : type === 'RETURN' ? 'Devolução pós-serviço' : 'Baixa de estoque manual'),
        timestamp: new Date().toISOString()
      };
      
      setStockMovements(prev => [newMov, ...prev]);
      addLog(`Registro de Estoque: ${type === 'ENTRY' ? 'Entrada de' : type === 'RETURN' ? 'Devolução de' : 'Saída de'} ${qty} un. de [${targetItemName}] registrada com sucesso no ledger.`, 'success');
    }
  };

  const handleTriggerPurchaseRequest = (itemId: string, qty: number) => {
    handleAddStockMovement(itemId, 'ENTRY', qty, 'Reabastecimento automático via requisição de compra do Back-Office');
  };

  // Trigger Gemini vision analysis simulator
  const runGeminiInspection = () => {
    if (geminiStatus === 'scanning') return;
    setGeminiStatus('scanning');
    addLog(`Enviando foto da peça para análise computacional do Gemini Vision...`, 'info');

    setTimeout(() => {
      // Simulate response
      const matched = inspectionPart.toLowerCase().includes('freio') || inspectionPart.toLowerCase().includes('banco') || inspectionPart.toLowerCase().includes('óleo');
      const mockScore = parseFloat((85 + Math.random() * 14).toFixed(1));
      const response = {
        part_recognized: inspectionPart,
        is_correct_part_for_order: true,
        confidence_score: mockScore,
        visual_anomalies_detected: [damagePreset],
        gemini_safety_rating: 'WARN' as const
      };

      setGeminiResult(response);
      setGeminiStatus('done');

      // Add state record representation
      const newValidation: ChecklistValidation = {
        id: `val-${Date.now()}`,
        service_order_id: selectedOSId,
        uploaded_image_url: `checklist_images/${selectedOSId}/${inspectionPart.replace(/\s+/g, '_').toLowerCase()}.png`,
        part_name: inspectionPart,
        pre_existing_damage: damagePreset,
        gemini_validation_response: response,
        validated: matched,
        checked_at: new Date().toISOString()
      };

      setValidations(prev => [newValidation, ...prev]);
      addLog(`Gemini Visual AI validado com ${mockScore}% de confiança! Banco atualizado: checklist_validations.`, 'success');
    }, 2000);
  };

  // Trigger Loyalty Points add / reserve bike evaluator
  const handleAddLoyaltyPoints = (userId: string, pts: number) => {
    setLoyalty(prev => prev.map(prof => {
      if (prof.client_id === userId) {
        const newBalance = prof.points_balance + pts;
        const reachedReserveBike = newBalance >= 500;
        const previousBikeAccess = prof.has_reserve_bike_access;

        if (reachedReserveBike && !previousBikeAccess) {
          addLog(`Programa Fidelidade: Cliente ganhou acesso ao benefício Moto Reserva com ${newBalance} pontos!`, 'success');
        } else {
          addLog(`Adicionado +${pts} pontos para o perfil do cliente no banco de dados. Pontos totais: ${newBalance}.`, 'info');
        }

        return {
          ...prof,
          points_balance: newBalance,
          has_reserve_bike_access: reachedReserveBike
        };
      }
      return prof;
    }));
  };

  // Copy text helper
  const copyToClipboard = (text: string, type: 'sql' | 'env' | number) => {
    navigator.clipboard.writeText(text);
    if (type === 'sql') {
      setCopiedSQL(true);
      setTimeout(() => setCopiedSQL(false), 2000);
    } else if (type === 'env') {
      setCopiedEnv(true);
      setTimeout(() => setCopiedEnv(false), 2000);
    } else {
      setCopiedCodeIndex(type);
      setTimeout(() => setCopiedCodeIndex(null), 2000);
    }
  };

  const dynamicSQL = getGeneratedSQL({ cancelMinutes, displacementTax, pointsPerBrl: 10, enableRls });

  return (
    <div className="min-h-screen bg-zinc-950 text-zinc-100 font-sans selection:bg-brand-orange selection:text-black">
      {/* Dynamic Header */}
      <header className="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur sticky top-0 z-50">
        <div className="max-w-7xl mx-auto px-4 py-3 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div className="flex items-center gap-3">
            <div className="flex items-center">
              <svg viewBox="0 0 310 100" className="h-10 text-brand-orange fill-current" xmlns="http://www.w3.org/2000/svg">
                <g fill="currentColor">
                  {/* Speed dynamic loop matching OttoMotos logo */}
                  <path d="M 45 15 C 20 15 0 35 0 60 C 0 85 20 105 45 105 C 62 105 76 95 82 81 C 84 76 81 71 76 71 C 72 71 69 73 67 77 C 63 85 55 90 45 90 C 28 90 15 77 15 60 C 15 43 28 30 45 30 C 56 30 65 36 69 46 C 71 51 75 53 79 51 C 83 50 85 46 83 42 C 76 26 62 15 45 15 Z" />
