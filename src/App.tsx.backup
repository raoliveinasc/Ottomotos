                                    <td className="p-2.5">
                                      <span className={`px-2 py-0.5 rounded-full text-[10px] font-bold ${
                                        o.status === 'CANCELLED'
                                          ? 'bg-red-500/10 text-red-400 border border-red-500/20'
                                          : o.status === 'IN_PROGRESS'
                                          ? 'bg-brand-orange-light text-brand-orange border border-brand-orange/20'
