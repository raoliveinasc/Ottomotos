                                    cancellationTimeOffset === 15 ? 'bg-zinc-800 text-brand-orange border border-brand-orange/45' : 'bg-zinc-900 text-zinc-400'
                                  }`}
                                >
                                  15 Min (Grátis)
                                </button>
                                <button
                                  onClick={() => setCancellationTimeOffset(45)}
