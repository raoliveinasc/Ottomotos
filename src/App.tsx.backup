                        </div>

                      </div>

                      {/* Right Side: Interactive CSS Phone Chassis Simulator */}
                      <div className="xl:col-span-5 flex flex-col justify-center items-center">
                        <span className="text-[11px] font-bold uppercase tracking-widest text-zinc-500 mb-3 block">Simulação de Smartphone Ativo</span>
                        
                        {/* Device Shell Chassis */}
                        <div className="max-w-[320px] w-full h-[620px] bg-zinc-950 border-[10px] border-zinc-800 rounded-[38px] shadow-2xl relative flex flex-col overflow-hidden text-zinc-100 select-none">
                          {/* Island / Notch details */}
                          <div className="absolute top-2 left-1/2 -translate-x-1/2 w-28 h-4 bg-black rounded-full z-40 flex items-center justify-around px-1">
                            <div className="w-2.5 h-2.5 bg-zinc-900 rounded-full border border-zinc-950 animate-pulse"></div>
                            <div className="w-6 h-0.5 bg-zinc-900 rounded-full"></div>
                          </div>

                          {/* Mobile Phone Status Bar */}
                          <div className="bg-zinc-950 py-1.5 px-6 flex justify-between items-center text-[10px] text-zinc-400 font-mono z-30 shrink-0">
                            <span>12:45 UTC</span>
                            <div className="flex items-center gap-1">
                              <span>5G</span>
                              <div className="flex gap-[1px]">
                                <div className="w-[2px] h-[3px] bg-zinc-400"></div>
                                <div className="w-[2px] h-[5px] bg-zinc-400"></div>
                                <div className="w-[2px] h-[7px] bg-zinc-400"></div>
                                <div className="w-[2px] h-[10px] bg-zinc-400"></div>
                              </div>
                              <div className="w-5 h-2.5 border border-zinc-400 rounded-sm relative p-[1px] flex">
                                <div className="bg-emerald-400 h-full w-[85%] rounded-2xs"></div>
                                <div className="w-[1px] h-[4px] bg-zinc-400 absolute -right-[2px] top-[2px]"></div>
                              </div>
                            </div>
                          </div>

                          {/* App content workspace inside Phone */}
                          <div className="flex-1 bg-zinc-900 p-4 overflow-y-auto flex flex-col justify-between scrollbar-none">
                            
                            {/* Inner App Header */}
                            <div className="flex justify-between items-center border-b border-zinc-800 pb-2 mb-3">
                              <span className="text-xs font-black tracking-tight text-white flex items-center gap-1">
                                <svg viewBox="0 0 310 100" className="h-4 text-brand-orange fill-current" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M 45 15 C 20 15 0 35 0 60 C 0 85 20 105 45 105 C 62 105 76 95 82 81 C 84 76 81 71 76 71 C 72 71 69 73 67 77 C 63 85 55 90 45 90 C 28 90 15 77 15 60 C 15 43 28 30 45 30 C 56 30 65 36 69 46 C 71 51 75 53 79 51 C 83 50 85 46 83 42 C 76 26 62 15 45 15 Z" />
                                </svg>
                                OTTO MOTOS
                              </span>
                              <span className="text-[9px] font-mono text-zinc-500 uppercase tracking-widest font-black">MOBILE-APP</span>
                            </div>

                            {/* SCREEN CONTENT: mechanic */}
                            {mobileScreen === 'mechanic' && (() => {
                              const selectedOS = orders.find(o => o.id === mechActiveOSId) || orders[0];
                              const chk = getMechChecklist(selectedOS.id);
                              
                              const postChecklistItemsList = [
                                { key: 'calibragem', label: '1. Calibragem Pneus', desc: 'Dianteiro e traseiro calibrados na van' },
                                { key: 'setas', label: '2. Setas Direcionais', desc: 'Luzes de sinalização e alertas piscando' },
                                { key: 'partida', label: '3. Partida Elétrica', desc: 'Ignição firme e rotação estável' },
                                { key: 'buzina', label: '4. Buzina Técnica', desc: 'Sinalizador acústico operacional' },
                                { key: 'freio_dianteiro', label: '5. Freio Dianteiro', desc: 'Manete regulado e pastilha verificada' },
                                { key: 'freio_traseiro', label: '6. Freio Traseiro', desc: 'Resposta imediata do pedal/manete' },
                                { key: 'nivel_oleo', label: '7. Nível de Óleo', desc: 'Vareta inspecionada no motor' },
                                { key: 'suspensao', label: '8. Suspensão Dianteira', desc: 'Sem vazamento em retentores de bengala' },
                                { key: 'aperto_guidao', label: '9. Aperto do Guidão', desc: 'Torque correto nos parafusos da mesa' },
                                { key: 'lubrificacao', label: '10. Lubrificação', desc: 'Relação de corrente ajustada e lubrificada' }
                              ];

                              const checkedCount = Object.values(chk.post_items).filter(Boolean).length;
                              const isPostAllChecked = checkedCount === 10;

                              const formatTime = (secs: number) => {
                                const m = Math.floor(secs / 60).toString().padStart(2, '0');
                                const s = (secs % 60).toString().padStart(2, '0');
                                return `${m}:${s}`;
                              };

                              return (
                                <div className="space-y-2 flex-1 flex flex-col justify-between text-xs">
                                  {/* Select O.S. & Vehicle Info */}
                                  <div className="space-y-1.5 shrink-0">
                                    <div className="flex gap-1.5 items-center justify-between">
                                      <span className="text-[10px] font-black tracking-widest text-zinc-400 uppercase">Tablet da Van:</span>
                                      <select
                                        value={mechActiveOSId}
                                        onChange={(e) => setMechActiveOSId(e.target.value)}
                                        className="bg-zinc-950 text-white font-extrabold text-[11px] rounded border border-zinc-850 px-2 py-1 outline-none max-w-[170px]"
                                      >
                                        {orders.map(o => (
                                          <option key={o.id} value={o.id}>
                                            O.S. #{o.id.replace('os-', '')} - {o.vehicle_plate}
                                          </option>
                                        ))}
                                      </select>
                                    </div>

                                    {/* Active OS Card Info */}
                                    <div className="bg-zinc-950 p-2 rounded border border-zinc-850 flex justify-between items-center">
                                      <div>
                                        <p className="text-zinc-400 text-[10px] font-semibold">{selectedOS.vehicle_model}</p>
                                        <p className="text-white text-xs font-black tracking-wider mt-0.5">{selectedOS.vehicle_plate}</p>
                                      </div>
                                      <div className="text-right">
                                        <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded uppercase ${
                                          selectedOS.status === 'PENDING' ? 'bg-zinc-800 text-zinc-400' :
                                          selectedOS.status === 'IN_PROGRESS' ? 'bg-brand-orange-light text-brand-orange animate-pulse' :
                                          selectedOS.status === 'COMPLETED' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' :
                                          'bg-amber-500/10 text-amber-400 border border-amber-500/20' // REMOVAL
                                        }`}>
                                          {selectedOS.status === 'PENDING' ? 'Aguardando' :
                                           selectedOS.status === 'IN_PROGRESS' ? 'SLA Ativo' :
                                           selectedOS.status === 'COMPLETED' ? 'Concluída' : 'Remoção'}
                                        </span>
                                      </div>
                                    </div>

                                     {/* SLA Stopwatch & Accept Flow (Uber Driver Style) */}
                                     {selectedOS.status === 'PENDING' ? (
                                       <div className="space-y-2.5">
                                         {/* Uber Driver Incoming Call Banner */}
                                         <div className="bg-amber-400 text-zinc-950 p-2 rounded-xl border border-amber-300 flex justify-between items-center animate-pulse shadow-sm">
                                           <div>
                                             <p className="text-[7.5px] font-black uppercase tracking-wider leading-none">Chamado Recebido • Uber Style 🔔</p>
                                             <h4 className="text-[10px] font-black mt-0.5 leading-tight">Novo Cliente Convocado</h4>
                                           </div>
                                           <span className="text-[9px] bg-black text-amber-400 font-mono font-black px-1.5 py-0.5 rounded-full">
                                             R$ 150,00+
                                           </span>
                                         </div>

                                         {/* Simulated GPS Route Map (Route Traced to Client) */}
                                         {/* Google Maps Route Map */}
                                         <div className="relative">
                                           <RoutingMap
                                             vanLocation={
                                               selectedOS.id === 'os-1002'
                                                 ? { lat: -23.5505, lng: -46.6333 }
                                                 : { lat: -23.5616, lng: -46.6560 }
                                             }
                                             clientLocation={
                                               selectedOS.id === 'os-1002'
                                                 ? { lat: -23.5415, lng: -46.6212 }
                                                 : { lat: -23.5714, lng: -46.6437 }
                                             }
                                             clientName={selectedOS.id === 'os-1002' ? 'Carlos Motoboy' : 'Carol Silva'}
                                             height="105px"
                                             onRouteComputed={(dist, dur) => {
                                               setRouteDistance(dist);
                                               setRouteDuration(dur);
                                             }}
                                           />
                                           {/* GPS distance stats banner */}
                                           <div className="absolute top-1.5 left-1.5 bg-black/85 border border-zinc-800 px-1.5 py-0.5 rounded text-[7px] font-mono text-zinc-300 z-10 leading-none space-y-0.5 shadow pointer-events-none">
                                             <p>Rota: <strong className="text-amber-400">{selectedOS.id === 'os-1002' ? 'Avenida do Estado' : 'Avenida Paulista'}</strong></p>
                                             <p>Distância: <strong className="text-amber-400">{routeDistance} ({routeDuration})</strong></p>
                                           </div>
                                         </div>

                                         {/* Action Accept Button */}
                                         <button
                                           onClick={() => {
                                             // Accept the O.S. & transition to IN_PROGRESS (SLA Active)
                                             setOrders(prev => prev.map(o => o.id === selectedOS.id ? { ...o, status: 'IN_PROGRESS' } : o));
                                             setMechChecklists(prev => ({
                                               ...prev,
                                               [selectedOS.id]: {
                                                 ...chk,
                                                 timer_active: true
                                               }
                                             }));
                                             addLog(`SLA O.S. #${selectedOS.id.replace('os-', '')}: Atendimento aceito e rota iniciada por Danilo.`, 'success');
                                           }}
                                           className="w-full bg-amber-400 hover:bg-amber-500 text-zinc-950 font-black text-[10px] py-2 rounded-xl transition-all flex items-center justify-center gap-1.5 shadow-md hover:shadow-lg hover:scale-[1.01] active:scale-[0.99] cursor-pointer animate-bounce"
                                         >
                                           🚐 ACEITAR ATENDIMENTO & TRACAR ROTA
                                         </button>
                                       </div>
                                     ) : (
                                       <div className="bg-zinc-950 p-2 rounded border border-zinc-850 flex items-center justify-between">
                                         <div className="flex items-center gap-1.5">
                                           <Clock className={`w-4 h-4 ${chk.timer_active ? 'text-brand-orange animate-spin' : 'text-zinc-500'}`} />
                                           <div>
                                             <p className="text-[8px] text-zinc-500 font-bold uppercase tracking-wider">Cronômetro SLA</p>
                                             <p className="text-white font-mono text-sm font-extrabold tracking-widest leading-none mt-0.5">
                                               {formatTime(chk.timer_seconds)}
                                             </p>
                                           </div>
                                         </div>
                                         <div className="flex gap-1">
                                           {selectedOS.status === 'IN_PROGRESS' && (
                                             <button
                                               onClick={() => {
                                                 if (!chk.pre_completed) {
                                                   alert("Erro: O Checklist de Pré-Execução é obrigatório e deve ser finalizado antes de concluir a O.S.");
                                                   return;
                                                 }
                                                 if (!isPostAllChecked) {
                                                   alert("Erro: Todos os 10 itens do Checklist de Pós-Execução devem ser verificados para segurança.");
                                                   return;
                                                 }
                                                 // Complete repair
                                                 setOrders(prev => prev.map(o => o.id === selectedOS.id ? { ...o, status: 'COMPLETED', end_time: new Date().toISOString() } : o));
                                                 setMechChecklists(prev => ({
                                                   ...prev,
                                                   [selectedOS.id]: {
                                                     ...chk,
                                                     timer_active: false,
                                                     timer_done: true,
                                                     post_completed: true
                                                   }
                                                 }));
                                                 addLog(`SLA O.S. #${selectedOS.id.replace('os-', '')}: Reparo finalizado com sucesso em ${formatTime(chk.timer_seconds)} minutos.`, 'success');
                                               }}
                                               disabled={!chk.pre_completed || !isPostAllChecked}
                                               className="bg-emerald-500 hover:bg-emerald-600 disabled:opacity-40 disabled:cursor-not-allowed text-black font-extrabold text-[10px] px-2.5 py-1 rounded transition-all cursor-pointer flex items-center gap-1"
                                             >
                                               <Check className="w-3 h-3 stroke-[3]" /> Concluir Serviço
                                             </button>
                                           )}
                                           {selectedOS.status === 'COMPLETED' && (
                                             <span className="text-emerald-400 font-bold text-[10px] flex items-center gap-1 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">
                                               <Check className="w-3 h-3" /> Finalizado
                                             </span>
                                           )}
                                           {selectedOS.status === 'REMOVAL' && (
                                             <span className="text-amber-400 font-bold text-[10px] flex items-center gap-1 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20">
                                               <Truck className="w-3.5 h-3.5" /> Remoção Ativa
                                             </span>
                                           )}
                                         </div>
                                       </div>
                                     )}
                                   </div>

                                  {/* App Tab Navigation */}
                                  <div className="grid grid-cols-3 bg-zinc-950 p-0.5 rounded-lg border border-zinc-850 shrink-0">
                                    <button
                                      onClick={() => setMechSubTab('pre')}
                                      className={`py-1 text-[9px] font-extrabold rounded transition-all cursor-pointer ${
                                        mechSubTab === 'pre' ? 'bg-zinc-800 text-white' : 'text-zinc-500 hover:text-zinc-300'
                                      }`}
                                    >
                                      1. Pré-Execução {chk.pre_completed && "✓"}
                                    </button>
                                    <button
                                      onClick={() => setMechSubTab('post')}
                                      className={`py-1 text-[9px] font-extrabold rounded transition-all cursor-pointer ${
                                        mechSubTab === 'post' ? 'bg-zinc-800 text-white' : 'text-zinc-500 hover:text-zinc-300'
                                      }`}
                                    >
                                      2. Pós (10 Itens) {isPostAllChecked && "✓"}
                                    </button>
                                    <button
                                      onClick={() => setMechSubTab('removal')}
                                      className={`py-1 text-[9px] font-extrabold rounded transition-all cursor-pointer ${
                                        mechSubTab === 'removal' ? 'bg-zinc-800 text-white' : 'text-zinc-500 hover:text-zinc-300'
                                      }`}
                                    >
                                      3. Remoção {selectedOS.status === 'REMOVAL' && "✓"}
                                    </button>
                                  </div>

                                  {/* Tab Contents */}
                                  <div className="flex-1 overflow-y-auto max-h-[300px] pr-0.5 space-y-2 scrollbar-none">
                                    
                                    {/* TAB 1: PRE-EXECUÇÃO */}
                                    {mechSubTab === 'pre' && (
                                      <div className="space-y-2.5">
                                        <div className="bg-zinc-950 p-2.5 rounded border border-zinc-850 space-y-2">
                                          <div className="flex justify-between items-center">
                                            <span className="text-[9px] text-zinc-400 uppercase font-black tracking-widest">Avarias Pré-Existentes</span>
                                            <span className={`text-[8px] px-1 rounded uppercase font-bold ${chk.pre_completed ? 'bg-emerald-500/10 text-emerald-400' : 'bg-red-500/10 text-red-400'}`}>
                                              {chk.pre_completed ? 'Fechado/Audita' : 'Preenchimento Obrigatório'}
                                            </span>
                                          </div>
                                          
                                          <p className="text-[10px] text-zinc-400 leading-normal">
                                            Selecione avarias físicas pré-existentes na moto para auditoria visual preventiva:
                                          </p>

                                          <div className="grid grid-cols-2 gap-1.5 text-[10px]">
                                            {[
                                              'Banco Rasgado',
                                              'Retrovisor Quebrado/Ausente',
                                              'Carenagem Riscada',
                                              'Manete de Freio Torto',
                                              'Seta Danificada',
                                              'Farol Trincado'
                                            ].map(dmg => {
                                              const isChecked = chk.pre_damages.includes(dmg);
                                              return (
                                                <label
                                                  key={dmg}
                                                  className={`flex items-center gap-1.5 p-1.5 rounded border cursor-pointer select-none transition-all ${
                                                    isChecked 
                                                      ? 'bg-zinc-900 border-brand-orange text-white' 
                                                      : 'bg-zinc-950 border-zinc-850 text-zinc-400 hover:border-zinc-800'
                                                  }`}
                                                  onClick={() => {
                                                    if (chk.pre_completed) return;
                                                    setMechChecklists(prev => {
                                                      const item = { ...prev[selectedOS.id] };
                                                      if (item.pre_damages.includes(dmg)) {
                                                        item.pre_damages = item.pre_damages.filter(d => d !== dmg);
                                                      } else {
                                                        item.pre_damages = [...item.pre_damages, dmg];
                                                      }
                                                      return { ...prev, [selectedOS.id]: item };
                                                    });
                                                  }}
                                                >
                                                  <input
                                                    type="checkbox"
                                                    checked={isChecked}
                                                    disabled={chk.pre_completed}
                                                    readOnly
                                                    className="accent-brand-orange w-3.5 h-3.5 shrink-0"
                                                  />
                                                  <span className="truncate">{dmg}</span>
                                                </label>
                                              );
                                            })}
                                          </div>

                                          <div className="space-y-1">
                                            <label className="text-[9px] text-zinc-500 uppercase font-bold">Observações Adicionais:</label>
                                            <textarea
                                              value={chk.pre_notes}
                                              disabled={chk.pre_completed}
                                              onChange={(e) => {
                                                const val = e.target.value;
                                                setMechChecklists(prev => {
                                                  const item = { ...prev[selectedOS.id] };
                                                  item.pre_notes = val;
                                                  return { ...prev, [selectedOS.id]: item };
                                                });
                                              }}
                                              placeholder="Descreva detalhes como riscados profundos, amassados..."
                                              className="w-full bg-zinc-900 border border-zinc-800 rounded p-1.5 text-[10px] text-white placeholder-zinc-600 outline-none h-12 resize-none"
                                            />
                                          </div>

                                          {/* Camera Simulation for Auditoria Visual */}
                                          <div className="space-y-1">
                                            <label className="text-[9px] text-zinc-500 uppercase font-bold block">Foto do Estado de Entrada (Auditoria Visual):</label>
                                            
                                            <div className="border border-dashed border-zinc-800 bg-zinc-900/60 rounded p-2 text-center flex flex-col items-center justify-center min-h-[80px] relative overflow-hidden">
                                              {chk.pre_photo_status === 'idle' && !chk.pre_photo && (
                                                <>
                                                  <Camera className="w-5 h-5 text-zinc-500 mb-1 animate-pulse" />
                                                  <p className="text-[9px] text-zinc-500 leading-normal">Nenhum registro fotográfico anexado</p>
                                                </>
                                              )}

                                              {chk.pre_photo_status === 'taking' && (
                                                <div className="space-y-1 py-1">
                                                  <div className="w-3.5 h-3.5 rounded-full bg-red-500 animate-ping mx-auto"></div>
                                                  <p className="text-[10px] text-zinc-300 font-bold font-mono">Disparando Câmera da Van...</p>
                                                </div>
                                              )}

                                              {chk.pre_photo_status === 'processing' && (
                                                <div className="space-y-1 py-1">
                                                  <RefreshCw className="w-3.5 h-3.5 text-brand-orange animate-spin mx-auto" />
                                                  <p className="text-[10px] text-zinc-300 font-bold font-mono">Análise de IA Gemini Vision...</p>
                                                </div>
                                              )}

                                              {(chk.pre_photo_status === 'done' || chk.pre_photo) && (
                                                <div className="text-center">
                                                  <img 
                                                    src={chk.pre_photo || "https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&q=80&w=200"} 
                                                    alt="Avaria pré-existente" 
                                                    className="w-24 h-16 rounded object-cover mx-auto border border-zinc-700" 
                                                    referrerPolicy="no-referrer" 
                                                  />
                                                  <p className="text-[8px] text-emerald-400 font-bold mt-1 inline-flex items-center gap-0.5">
                                                    <Check className="w-3 h-3" /> Foto vinculada ao laudo da O.S.
                                                  </p>
                                                </div>
                                              )}
                                            </div>

                                            {!chk.pre_completed && (
                                              <button
                                                onClick={() => {
                                                  // Simulate taking picture
                                                  setMechChecklists(prev => {
                                                    const item = { ...prev[selectedOS.id] };
                                                    item.pre_photo_status = 'taking';
                                                    return { ...prev, [selectedOS.id]: item };
                                                  });
                                                  
                                                  setTimeout(() => {
                                                    setMechChecklists(prev => {
                                                      const item = { ...prev[selectedOS.id] };
                                                      item.pre_photo_status = 'processing';
                                                      return { ...prev, [selectedOS.id]: item };
                                                    });
                                                    
                                                    setTimeout(() => {
                                                      setMechChecklists(prev => {
                                                        const item = { ...prev[selectedOS.id] };
                                                        item.pre_photo_status = 'done';
                                                        item.pre_photo = 'https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&q=80&w=200';
                                                        return { ...prev, [selectedOS.id]: item };
                                                      });
                                                      addLog(`Auditoria de Entrada: Foto anexada à O.S. #${selectedOS.id.replace('os-', '')} com sucesso.`, 'success');
                                                    }, 1500);
                                                  }, 1000);
                                                }}
                                                disabled={chk.pre_photo_status !== 'idle' && chk.pre_photo_status !== 'done'}
                                                className="w-full mt-1.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold text-[10px] py-1 rounded transition-all cursor-pointer flex items-center justify-center gap-1"
                                              >
                                                <Camera className="w-3 h-3 text-brand-orange" /> Fotografar Avaria Física
                                              </button>
                                            )}
                                          </div>

                                          {/* Seal Pre-execution checklist button */}
                                          {!chk.pre_completed && (
                                            <button
                                              onClick={() => {
                                                if (!chk.pre_photo && chk.pre_damages.length === 0 && !chk.pre_notes) {
                                                  alert("Erro: Para fechar o checklist de pré-execução você deve tirar a foto da moto ou marcar alguma avaria detectada.");
                                                  return;
                                                }
                                                setMechChecklists(prev => {
                                                  const item = { ...prev[selectedOS.id] };
                                                  item.pre_completed = true;
                                                  return { ...prev, [selectedOS.id]: item };
                                                });
                                                setMechSubTab('post'); // Auto advance!
                                                addLog(`Checklist Pré-Execução Selado: O.S. #${selectedOS.id.replace('os-', '')} liberada para manutenção.`, 'info');
                                              }}
                                              className="w-full mt-1 bg-brand-orange hover:bg-brand-orange-hover text-black font-extrabold text-[10px] py-1.5 rounded transition-all flex items-center justify-center gap-1 cursor-pointer"
                                            >
                                              <ShieldCheck className="w-3.5 h-3.5" /> Confirmar e Selar Pré-Execução
                                            </button>
                                          )}
                                        </div>
                                      </div>
                                    )}

                                    {/* TAB 2: PÓS-EXECUÇÃO */}
                                    {mechSubTab === 'post' && (
                                      <div className="space-y-2">
                                        {!chk.pre_completed ? (
                                          <div className="bg-zinc-950 border border-red-900/30 p-4 rounded text-center space-y-2">
                                            <AlertTriangle className="w-6 h-6 text-red-400 mx-auto animate-bounce" />
                                            <p className="text-[10px] text-zinc-400">
                                              O Checklist de **Pré-Execução (Auditoria de Entrada)** deve ser concluído e selado antes de iniciar a revisão final de saída.
                                            </p>
                                            <button
                                              onClick={() => setMechSubTab('pre')}
                                              className="text-[9px] text-brand-orange font-bold hover:underline"
                                            >
                                              Ir para Pré-Execução →
                                            </button>
                                          </div>
                                        ) : (
                                          <div className="bg-zinc-950 p-2.5 rounded border border-zinc-850 space-y-2">
                                            <div className="flex justify-between items-center">
                                              <span className="text-[9px] text-zinc-400 uppercase font-black tracking-widest">Revisão de 10 Itens Obrigatórios</span>
                                              <span className={`font-mono text-[9px] font-bold px-1.5 py-0.5 rounded ${isPostAllChecked ? 'bg-emerald-500/10 text-emerald-400' : 'bg-brand-orange-light text-brand-orange'}`}>
                                                {checkedCount}/10 Concluídos
                                              </span>
                                            </div>

                                            {/* Progress bar */}
                                            <div className="w-full bg-zinc-900 h-1 rounded-full overflow-hidden">
                                              <div 
                                                className="bg-brand-orange h-full transition-all duration-300" 
                                                style={{ width: `${checkedCount * 10}%` }}
                                              ></div>
                                            </div>

                                            <p className="text-[9px] text-zinc-400 leading-normal mb-1">
                                              A OttoMotos exige conformidade total. Teste e confirme cada um dos 10 subsistemas abaixo antes de liberar a moto:
                                            </p>

                                            <div className="space-y-1 max-h-[220px] overflow-y-auto pr-1 scrollbar-none">
                                              {postChecklistItemsList.map(item => {
                                                const isChecked = chk.post_items[item.key];
                                                return (
                                                  <label
                                                    key={item.key}
                                                    className={`flex items-start gap-2 p-1.5 rounded border transition-all cursor-pointer ${
                                                      isChecked 
                                                        ? 'bg-zinc-900 border-zinc-800 text-zinc-200' 
                                                        : 'bg-zinc-950 border-zinc-900 text-zinc-500 hover:border-zinc-850'
                                                    }`}
                                                    onClick={() => {
                                                      if (selectedOS.status === 'COMPLETED' || selectedOS.status === 'REMOVAL') return;
                                                      setMechChecklists(prev => {
                                                        const itemObj = { ...prev[selectedOS.id] };
                                                        itemObj.post_items = {
                                                          ...itemObj.post_items,
                                                          [item.key]: !itemObj.post_items[item.key]
                                                        };
                                                        return { ...prev, [selectedOS.id]: itemObj };
                                                      });
                                                    }}
                                                  >
                                                    <input
                                                      type="checkbox"
                                                      checked={isChecked}
                                                      disabled={selectedOS.status === 'COMPLETED' || selectedOS.status === 'REMOVAL'}
                                                      readOnly
                                                      className="accent-brand-orange w-3.5 h-3.5 shrink-0 mt-0.5"
                                                    />
                                                    <div className="text-[10px] leading-tight">
                                                      <span className={`font-bold ${isChecked ? 'text-zinc-200' : 'text-zinc-400'}`}>
                                                        {item.label}
                                                      </span>
                                                      <p className="text-[8.5px] text-zinc-500 font-normal leading-normal">{item.desc}</p>
                                                    </div>
                                                  </label>
                                                );
                                              })}
                                            </div>

                                            {isPostAllChecked && selectedOS.status === 'IN_PROGRESS' && (
                                              <div className="bg-emerald-500/10 border border-emerald-500/20 p-2 rounded text-emerald-400 text-[9px] leading-relaxed text-center font-bold">
                                                ✓ Perfeito! Todos os 10 itens de segurança foram revisados e aprovados na van.
                                              </div>
                                            )}
                                          </div>
                                        )}
                                      </div>
                                    )}

                                    {/* TAB 3: REMOÇÃO */}
                                    {mechSubTab === 'removal' && (
                                      <div className="space-y-2.5">
                                        <div className="bg-zinc-950 p-2.5 rounded border border-zinc-850 space-y-2">
                                          <div className="flex items-center gap-1 text-amber-400 font-bold">
                                            <AlertTriangle className="w-4 h-4 shrink-0 animate-pulse" />
                                            <span className="text-[9px] text-zinc-300 uppercase font-black tracking-widest">Protocolo de Remoção Van</span>
                                          </div>

                                          <p className="text-[10px] text-zinc-400 leading-normal">
                                            Se o reparo exigir maquinário industrial ou for perigoso para as ruas, mude o status para **Remoção** e embarque a moto:
                                          </p>

                                          {/* Step-by-step guidance */}
                                          <div className="p-2 bg-zinc-900 rounded border border-zinc-800 space-y-2 text-[10px] text-zinc-300">
                                            <h6 className="font-extrabold text-white text-[9.5px] border-b border-zinc-800 pb-1 flex items-center gap-1">
                                              <Truck className="w-3.5 h-3.5 text-brand-orange" /> Passo a Passo de Segurança
                                            </h6>
                                            <ol className="list-decimal list-inside space-y-1.5 leading-relaxed text-[9px] text-zinc-400">
                                              <li>
                                                <strong className="text-zinc-200">Rampa de Alumínio</strong>: Estenda a rampa traseira da van e fixe os pinos de segurança.
                                              </li>
                                              <li>
                                                <strong className="text-zinc-200">Embarque da Moto</strong>: Suba a moto lentamente pela rampa centralizada com auxílio.
                                              </li>
                                              <li>
                                                <strong className="text-zinc-200">Cintas de Amarração</strong>: Prenda e tencione as <strong>cintas de catraca</strong> (2 no guidão, 2 na traseira) tensionando até as suspensões comprimirem de leve.
                                              </li>
                                            </ol>
                                          </div>

                                          {selectedOS.status !== 'REMOVAL' && selectedOS.status !== 'COMPLETED' && (
                                            <div className="space-y-2.5 pt-1">
                                              <div className="space-y-1">
                                                <label className="text-[9px] text-zinc-500 uppercase font-bold block">Justificativa Técnica:</label>
                                                <textarea
                                                  value={chk.removal_reason}
                                                  onChange={(e) => {
                                                    const val = e.target.value;
                                                    setMechChecklists(prev => ({
                                                      ...prev,
                                                      [selectedOS.id]: {
                                                        ...chk,
                                                        removal_reason: val
                                                      }
                                                    }));
                                                  }}
                                                  placeholder="Ex: Motor com quebra interna no cabeçote impossível de sanar em campo..."
                                                  className="w-full bg-zinc-900 border border-zinc-800 rounded p-1.5 text-[10px] text-white placeholder-zinc-600 outline-none h-12 resize-none"
                                                />
                                              </div>

                                              <label className="flex items-start gap-1.5 p-2 rounded bg-zinc-900 border border-zinc-850 cursor-pointer select-none">
                                                <input
                                                  type="checkbox"
                                                  checked={chk.removal_confirmed}
                                                  onChange={(e) => {
                                                    const checked = e.target.checked;
                                                    setMechChecklists(prev => ({
                                                      ...prev,
                                                      [selectedOS.id]: {
                                                        ...chk,
                                                        removal_confirmed: checked
                                                      }
                                                    }));
                                                  }}
                                                  className="accent-brand-orange w-4.5 h-4.5 mt-0.5 shrink-0"
                                                />
                                                <span className="text-[9px] text-zinc-400 leading-tight">
                                                  Declaro que fixei a moto utilizando as **cintas de amarração com catraca** na rampa da van de forma segura e imóvel.
                                                </span>
                                              </label>

                                              <button
                                                onClick={() => {
                                                  if (!chk.removal_reason.trim()) {
                                                    alert("Por favor, preencha a Justificativa Técnica explicando o motivo da complexidade.");
                                                    return;
                                                  }
                                                  if (!chk.removal_confirmed) {
                                                    alert("Por favor, declare que fixou a moto de forma segura utilizando as cintas de amarração.");
                                                    return;
                                                  }

                                                  // Set to Removal status
                                                  setOrders(prev => prev.map(o => o.id === selectedOS.id ? { ...o, status: 'REMOVAL' } : o));
                                                  setMechChecklists(prev => ({
                                                    ...prev,
                                                    [selectedOS.id]: {
                                                      ...chk,
                                                      timer_active: false,
                                                      is_removal_triggered: true
                                                    }
                                                  }));
                                                  addLog(`O.S. #${selectedOS.id.replace('os-', '')} transferida para REMOÇÃO por Danilo. Veículo embarcado com cintas na rampa da van.`, 'warning');
                                                }}
                                                className="w-full bg-amber-500 hover:bg-amber-600 text-black font-extrabold text-[10px] py-2 rounded transition-all flex items-center justify-center gap-1.5 cursor-pointer"
                                              >
                                                <Truck className="w-4 h-4" /> Confirmar Transporte para Oficina Base
                                              </button>
                                            </div>
                                          )}

                                          {selectedOS.status === 'REMOVAL' && (
                                            <div className="bg-amber-500/10 border border-amber-500/20 p-2.5 rounded space-y-1.5 text-amber-400">
                                              <p className="font-bold text-[10px] flex items-center gap-1">
                                                <Check className="w-3.5 h-3.5 stroke-[3]" /> PROTOCOLO DE REMOÇÃO EXECUTADO
                                              </p>
                                              <p className="text-[9.5px] text-zinc-300 leading-normal">
                                                A moto foi fixada e trancada com cintas e está em trânsito para a unidade física.
                                              </p>
                                              <div className="text-[9px] text-zinc-400 leading-tight pt-1 border-t border-zinc-850">
                                                <strong>Justificativa Técnica:</strong> {chk.removal_reason}
                                              </div>
                                            </div>
                                          )}
                                        </div>
                                      </div>
                                    )}

                                  </div>

                                  {/* Info Footer */}
                                  <div className="bg-zinc-950 p-2 rounded border border-zinc-850/60 text-[9.5px] text-zinc-500 leading-tight">
                                    💡 <strong>Auditoria Visual & SLA:</strong> Este tablet sincroniza o tempo gasto na rua. O Checklist Pré é indispensável para evitar contestações de danos ao cliente.
                                  </div>
                                </div>
                              );
                            })()}

                            {/* SCREEN CONTENT: client */}
                            {mobileScreen === 'client' && (
                              <div className="space-y-2.5 flex-1 flex flex-col justify-between">
                                <div className="space-y-2 flex-1 flex flex-col">
                                  {/* Client Header Card */}
                                  <div className="bg-zinc-950 p-2 rounded border border-zinc-850/60 flex justify-between items-center">
                                    <div>
                                      <p className="text-[8px] text-zinc-500 uppercase tracking-widest font-black">Cliente Autenticado</p>
                                      <p className="text-white text-xs font-black">Carol Silva</p>
                                    </div>
                                    <div className="text-right">
                                      <p className="text-[8px] text-zinc-500 font-bold">Fidelidade</p>
                                      <p className="text-brand-orange text-xs font-extrabold font-mono">
                                        {loyalty.find(l => l.client_id === 'usr-client-1')?.points_balance || 150} pts
                                      </p>
                                    </div>
                                  </div>

                                  {/* Inner Sub-Navigation Tabs inside Phone */}
                                  <div className="grid grid-cols-3 gap-1 bg-zinc-950 p-0.5 rounded border border-zinc-900 text-[9px] font-bold">
                                    <button
                                      onClick={() => setClientSubTab('tracking')}
                                      className={`py-1 rounded text-center transition-all ${
                                        clientSubTab === 'tracking' ? 'bg-zinc-800 text-brand-orange' : 'text-zinc-400 hover:text-white'
                                      }`}
                                    >
                                      Acompanhar
                                    </button>
                                    <button
                                      onClick={() => setClientSubTab('schedule')}
                                      className={`py-1 rounded text-center transition-all ${
                                        clientSubTab === 'schedule' ? 'bg-zinc-800 text-brand-orange' : 'text-zinc-400 hover:text-white'
                                      }`}
                                    >
                                      Agendar
                                    </button>
                                    <button
                                      onClick={() => setClientSubTab('rewards')}
                                      className={`py-1 rounded text-center transition-all ${
                                        clientSubTab === 'rewards' ? 'bg-zinc-800 text-brand-orange' : 'text-zinc-400 hover:text-white'
                                      }`}
                                    >
                                      Fidelidade
                                    </button>
                                  </div>

                                  {/* CONTENT: Tracking tab with Uber/iFood styling */}
                                  {clientSubTab === 'tracking' && (
                                    <div className="space-y-3 flex-1 flex flex-col justify-between">
                                      {/* iFood style status tracker */}
                                      <div className="bg-white text-zinc-900 p-2.5 rounded-xl border border-zinc-200 shadow-sm space-y-2">
                                        <div className="flex justify-between items-center border-b border-zinc-100 pb-1.5">
                                          <span className="text-[10px] text-zinc-800 font-extrabold uppercase tracking-wide flex items-center gap-1">
                                            <span className="w-2 h-2 rounded-full bg-brand-orange animate-pulse"></span>
                                            Pedido #1001 • Honda Biz
                                          </span>
                                          <span className="text-[8px] bg-amber-100 text-brand-orange px-1.5 py-0.5 rounded-full font-extrabold uppercase">
                                            A Caminho
                                          </span>
                                        </div>

                                        {/* Status Steps */}
                                        <div className="grid grid-cols-3 gap-1 relative">
                                          {/* Step 1 */}
                                          <div className="flex flex-col items-center text-center">
                                            <div className="w-5 h-5 rounded-full bg-emerald-500 text-white flex items-center justify-center text-[10px] font-bold shadow-sm">
                                              ✓
                                            </div>
                                            <span className="text-[7.5px] font-bold text-zinc-800 mt-1 leading-tight">Orçamento<br/>Aprovado</span>
                                          </div>
                                          {/* Step 2 */}
                                          <div className="flex flex-col items-center text-center">
                                            <div className="w-5 h-5 rounded-full bg-brand-orange text-white flex items-center justify-center text-[10px] font-bold shadow-sm animate-bounce">
                                              🚐
                                            </div>
                                            <span className="text-[7.5px] font-black text-brand-orange mt-1 leading-tight">Mecânico<br/>a Caminho</span>
                                          </div>
                                          {/* Step 3 */}
                                          <div className="flex flex-col items-center text-center opacity-40">
                                            <div className="w-5 h-5 rounded-full bg-zinc-200 text-zinc-600 flex items-center justify-center text-[10px] font-bold">
                                              🔧
                                            </div>
                                            <span className="text-[7.5px] font-bold text-zinc-500 mt-1 leading-tight">Serviço em<br/>Execução</span>
                                          </div>
                                        </div>
                                      </div>

                                      {/* Uber style interactive simulated tracking map with Yellow Van icon */}
                                      {/* Real Google Maps tracking map */}
                                      <div className="relative">
                                        <RoutingMap
                                          vanLocation={{ lat: -23.5616, lng: -46.6560 }} // Carol's active Van
                                          clientLocation={{ lat: -23.5714, lng: -46.6437 }} // Carol's Home
                                          clientName="Carol Silva"
                                          height="115px"
                                          onRouteComputed={(dist, dur) => {
                                            setRouteDistance(dist);
                                            setRouteDuration(dur);
                                          }}
                                        />
                                        {/* Bottom distance box overlay */}
                                        <div className="absolute top-2 left-2 bg-black/85 border border-zinc-800 px-2 py-0.5 rounded text-[8px] font-mono text-zinc-300 z-10 pointer-events-none">
                                          Chegada em <strong className="text-brand-orange">{routeDuration}</strong> ({routeDistance})
                                        </div>
                                      </div>

                                      {/* Uber-style Bottom Sheet */}
                                      <div className="bg-white rounded-xl p-2.5 border border-zinc-200 shadow-md text-zinc-900 space-y-2">
                                        <div className="flex justify-between items-center">
                                          {/* Driver Profile */}
                                          <div className="flex items-center gap-2">
                                            <div className="w-8 h-8 rounded-full bg-zinc-900 border border-zinc-200 text-amber-400 flex items-center justify-center font-black text-xs relative shadow-inner">
                                              D
                                              <span className="absolute bottom-0 right-0 w-2 h-2 rounded-full bg-emerald-500 border border-white"></span>
                                            </div>
                                            <div>
                                              <h5 className="text-[10px] font-black text-zinc-950 flex items-center gap-1 leading-tight">
                                                Danilo Mecânico
                                                <span className="text-[8px] text-amber-500 font-extrabold flex items-center">
                                                  ★ 4.9
                                                </span>
                                              </h5>
                                              <p className="text-[8px] text-zinc-500">Mecânico Volante Especialista</p>
                                            </div>
                                          </div>

                                          {/* Vehicle Plate Badge */}
                                          <div className="text-right">
                                            <div className="bg-zinc-150 border border-zinc-300 text-zinc-800 font-extrabold px-1.5 py-0.5 rounded font-mono text-[9px] uppercase tracking-wider inline-block">
                                              OTTO-V01
                                            </div>
                                            <p className="text-[7.5px] text-zinc-400 mt-0.5 uppercase tracking-wide">Furgão Amarelo</p>
                                          </div>
                                        </div>

                                        {/* Contact button row using black and yellow colors */}
                                        <div className="grid grid-cols-2 gap-1.5 pt-0.5">
                                          <button 
                                            onClick={() => alert('Ligando para o mecânico Danilo via ramal seguro OttoMotos...')}
                                            className="bg-zinc-900 hover:bg-black text-white text-[8px] font-bold py-1.5 rounded-lg flex items-center justify-center gap-1 transition-all"
                                          >
                                            📞 Ligar para Danilo
                                          </button>
                                          <button 
                                            onClick={() => alert('Abrindo chat seguro OttoMotos com o mecânico Danilo...')}
                                            className="bg-amber-400 hover:bg-amber-500 text-zinc-950 text-[8px] font-black py-1.5 rounded-lg flex items-center justify-center gap-1 transition-all"
                                          >
                                            💬 Enviar Mensagem
                                          </button>
                                        </div>
                                      </div>

                                      {/* Collapsible live camera stream */}
                                      <div className="bg-zinc-950 border border-zinc-900 rounded-lg overflow-hidden">
                                        <button 
                                          onClick={() => setCameraOpen(!cameraOpen)} 
                                          className="w-full bg-zinc-900 hover:bg-zinc-850 px-2.5 py-1.5 text-[8.5px] font-bold text-zinc-400 flex justify-between items-center transition-all"
                                        >
                                          <span className="flex items-center gap-1 text-brand-orange">
                                            <Video className="w-3.5 h-3.5" />
                                            Ver Câmera IP do Furgão Amarelo
                                          </span>
                                          <span className="text-[7.5px] bg-zinc-850 px-1 py-0.5 rounded">
                                            {cameraOpen ? 'Ocultar ✕' : 'Expandir AO VIVO 🎥'}
                                          </span>
                                        </button>

                                        {cameraOpen && (
                                          <div className="p-1 space-y-1">
                                            {/* Immersive Stream Frame */}
                                            <div className="relative aspect-video bg-black flex flex-col justify-between p-1.5 rounded">
                                              {/* Top indicators overlay */}
                                              <div className="flex justify-between items-center text-[6px] font-mono z-10 text-white bg-black/60 px-1 py-0.5 rounded">
                                                <span className="flex items-center gap-1">
                                                  <span className="w-1 h-1 bg-red-500 rounded-full animate-ping"></span>
                                                  REC • TRANSMISSÃO AO FURGÃO
                                                </span>
                                                <span>30 FPS • HD</span>
                                              </div>

                                              {/* Video Canvas Graphic */}
                                              <div className="absolute inset-0 flex items-center justify-center pointer-events-none opacity-85">
                                                <svg viewBox="0 0 100 100" className="w-14 h-14 text-zinc-700">
                                                  <circle cx="50" cy="50" r="32" stroke="currentColor" strokeWidth="1" fill="none" strokeDasharray="3 1" className="animate-spin" />
                                                  <path d="M 25 50 L 75 50" stroke="currentColor" strokeWidth="0.5" />
                                                  <g transform="translate(50, 50) rotate(35)">
                                                    <rect x="-2" y="-15" width="4" height="10" fill="#FF5A00" className="animate-bounce" />
                                                    <circle cx="0" cy="-15" r="2" fill="#FF5A00" />
                                                  </g>
                                                </svg>
                                                <div className="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(255,255,255,0.01)_50%,rgba(0,0,0,0.06)_50%)] bg-[length:100%_4px]"></div>
                                              </div>

                                              {/* Bottom latency info */}
                                              <div className="flex justify-between items-center text-[6px] font-mono z-10 text-zinc-400 bg-black/60 px-1 py-0.5 rounded">
                                                <span className="text-emerald-400 font-bold flex items-center gap-0.5">
                                                  <Globe className="w-1.5 h-1.5" /> WebSockets Estável
                                                </span>
                                                <span>24ms</span>
                                              </div>
                                            </div>
                                          </div>
                                        )}
                                      </div>
                                    </div>
                                  )}

                                  {/* CONTENT: Agendamento & Orçamento tab */}
                                  {clientSubTab === 'schedule' && (
                                    <div className="space-y-2 flex-1 flex flex-col justify-between overflow-y-auto">
                                      <div className="space-y-2">
                                        <div className="text-center pb-1">
                                          <p className="text-[10px] text-white font-extrabold flex items-center justify-center gap-1">
                                            <Calendar className="w-3.5 h-3.5 text-brand-orange" />
                                            Orçamento & Agendamento Online
                                          </p>
                                          <p className="text-[8px] text-zinc-400">Monte o plano ideal para sua motocicleta</p>
                                        </div>

                                        {/* Service checkboxes (iFood-Style Cards) */}
                                        <div className="space-y-2">
                                          <span className="text-[8px] text-zinc-400 font-bold uppercase tracking-wider block">Serviços Disponíveis (Estilo iFood)</span>
                                          
                                          {services.map(srv => {
                                            const isSelected = selectedServices.includes(srv.id);
                                            // Get nice icon representing the service
                                            const getServiceIcon = (id: string) => {
                                              if (id === 'srv-1') return <span className="text-sm">🛢️</span>; // Óleo
                                              if (id === 'srv-2') return <span className="text-sm">🛞</span>; // Pastilha
                                              if (id === 'srv-3') return <span className="text-sm">⚙️</span>; // Kit Transmissão
                                              return <span className="text-sm">🔧</span>; // Revisão
                                            };

                                            return (
                                              <div 
                                                key={srv.id} 
                                                className={`flex items-center justify-between p-2 rounded-xl transition-all border ${
                                                  isSelected 
                                                    ? 'bg-amber-50/70 border-brand-orange text-zinc-950 shadow-sm' 
                                                    : 'bg-white border-zinc-200 text-zinc-900 hover:border-zinc-300'
                                                }`}
                                              >
                                                {/* Left side: piece illustration & info */}
                                                <div className="flex items-center gap-2 flex-1 min-w-0">
                                                  <div className={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 border ${
                                                    isSelected ? 'bg-amber-100 border-amber-300' : 'bg-zinc-100 border-zinc-200'
                                                  }`}>
                                                    {getServiceIcon(srv.id)}
                                                  </div>
                                                  <div className="min-w-0">
                                                    <span className="text-[9.5px] font-black uppercase tracking-tight block text-zinc-950 leading-tight truncate">
                                                      {srv.name.toLowerCase()}
                                                    </span>
                                                    <div className="flex items-center gap-2 mt-0.5">
                                                      <span className="text-[8.5px] text-brand-orange font-extrabold font-mono leading-none">
                                                        R$ {srv.base_price_brl.toFixed(2)}
                                                      </span>
                                                      <span className="text-[7.5px] text-zinc-500 font-semibold flex items-center gap-0.5 leading-none">
                                                        ⏱️ {srv.estimated_time_m} min
                                                      </span>
                                                    </div>
                                                  </div>
                                                </div>

                                                {/* Right side: custom orange addition button */}
                                                <button
                                                  onClick={() => {
                                                    if (isSelected) {
                                                      setSelectedServices(prev => prev.filter(id => id !== srv.id));
                                                    } else {
                                                      setSelectedServices(prev => [...prev, srv.id]);
                                                    }
                                                  }}
                                                  className={`h-6 px-2.5 rounded-lg text-[9px] font-black uppercase tracking-wide flex items-center justify-center transition-all ${
                                                    isSelected 
                                                      ? 'bg-zinc-900 hover:bg-black text-white' 
                                                      : 'bg-amber-400 hover:bg-amber-500 text-zinc-950'
                                                  }`}
                                                >
                                                  {isSelected ? 'Remover ✕' : 'Adicionar +'}
                                                </button>
                                              </div>
                                            );
                                          })}
                                        </div>

                                        {/* Attendance Model chooser */}
                                        <div className="space-y-1">
                                          <span className="text-[8px] text-zinc-500 font-bold uppercase tracking-wider block">Modalidade de Atendimento</span>
                                          <div className="grid grid-cols-2 gap-1.5">
                                            <button
                                              onClick={() => setAttendanceType('base')}
                                              className={`p-1.5 rounded border text-left transition-all flex flex-col justify-between ${
                                                attendanceType === 'base'
                                                  ? 'border-brand-orange bg-brand-orange-light text-brand-orange'
                                                  : 'border-zinc-800 bg-zinc-950 text-zinc-400'
                                              }`}
                                            >
                                              <span className="text-[9px] font-black uppercase">Na Base</span>
                                              <span className="text-[7px] text-zinc-400">Ir até a oficina</span>
                                            </button>
                                            
                                            <button
                                              onClick={() => setAttendanceType('van')}
                                              className={`p-1.5 rounded border text-left transition-all flex flex-col justify-between ${
                                                attendanceType === 'van'
                                                  ? 'border-brand-orange bg-brand-orange-light text-brand-orange'
                                                  : 'border-zinc-800 bg-zinc-950 text-zinc-400'
                                              }`}
                                            >
                                              <span className="text-[9px] font-black uppercase flex items-center gap-1">
                                                <Truck className="w-2.5 h-2.5" /> Van Móvel
                                              </span>
                                              <span className="text-[7px] text-zinc-400">Atendimento em casa</span>
                                            </button>
                                          </div>
                                        </div>

                                        {/* Realtime summation */}
                                        <div className="bg-zinc-950 p-2 rounded border border-zinc-850 text-[9px] space-y-1">
                                          <div className="flex justify-between text-zinc-400">
                                            <span>Serviços selecionados:</span>
                                            <span className="font-mono">R$ {services.filter(s => selectedServices.includes(s.id)).reduce((a, b) => a + b.base_price_brl, 0).toFixed(2)}</span>
                                          </div>
                                          <div className="flex justify-between text-zinc-400">
                                            <span>Taxa de deslocamento (van):</span>
                                            <span className="font-mono">R$ {(attendanceType === 'van' ? displacementTax : 0).toFixed(2)}</span>
                                          </div>
                                          <div className="flex justify-between text-white font-extrabold border-t border-zinc-900 pt-1 text-[10px]">
                                            <span>Orçamento Total:</span>
                                            <span className="text-brand-orange font-mono">
                                              R$ {(
                                                services.filter(s => selectedServices.includes(s.id)).reduce((a, b) => a + b.base_price_brl, 0) + 
                                                (attendanceType === 'van' ? displacementTax : 0)
                                              ).toFixed(2)}
                                            </span>
                                          </div>
                                        </div>

                                        {/* Cancellation Warning Rule */}
                                        <div className="bg-zinc-950 p-1.5 rounded border border-brand-orange/15 text-[8.5px] text-zinc-400 leading-normal">
                                          ⚠️ <strong>Prazo de Cancelamento:</strong> Cancelamento é <strong>totalmente isento</strong> se feito em até <strong>{cancelMinutes} minutos</strong>. Após este período, ou na retirada do veículo, gera taxa de deslocamento de <strong>R$ {displacementTax},00</strong>.
                                        </div>
                                      </div>

                                      {/* Confirm Trigger */}
                                      <button
                                        onClick={() => {
                                          const servicesTotal = services.filter(s => selectedServices.includes(s.id)).reduce((a, b) => a + b.base_price_brl, 0);
                                          const finalTax = attendanceType === 'van' ? displacementTax : 0;
                                          const totalVal = servicesTotal + finalTax;
                                          
                                          if (selectedServices.length === 0) {
                                            addLog("Erro de Agendamento: Selecione ao menos um serviço para o orçamento.", "warning");
                                            return;
                                          }

                                          const nextOSId = `os-${1000 + orders.length + 1}`;
                                          const newOS: ServiceOrder = {
                                            id: nextOSId,
                                            client_id: 'usr-client-1',
                                            mechanic_id: 'usr-mech-1',
                                            vehicle_plate: 'CAR-1001',
                                            vehicle_model: 'Honda Biz 125cc',
                                            start_time: new Date().toISOString(),
                                            end_time: null,
                                            attendance_model: attendanceType === 'van' ? 'Mobile' : 'Express',
                                            status: 'PENDING',
                                            displacement_tax: finalTax,
                                            ai_diagnostics: {
                                              pred_maintenance: "Revisão agendada via painel cliente.",
                                              anomaly_alerts: [],
                                              risk_level: "LOW",
                                              gemini_summary: "Aguardando checklist inicial na van/oficina."
                                            },
                                            created_at: new Date().toISOString()
                                          };

                                          setOrders(prev => [newOS, ...prev]);
                                          addLog(`Orçamento Criado: O.S. ${nextOSId} solicitada via ${attendanceType === 'van' ? 'Van Móvel' : 'Base'} no valor de R$ ${totalVal.toFixed(2)}. Regra de cancelamento ativa (${cancelMinutes} min isento).`, 'success');
                                          setClientSubTab('tracking');
                                        }}
                                        className="w-full bg-brand-orange hover:bg-brand-orange-hover text-black font-extrabold text-[10px] py-1.5 rounded cursor-pointer text-center uppercase"
                                      >
                                        Aprovar Orçamento & Agendar
                                      </button>
                                    </div>
                                  )}

                                  {/* CONTENT: Loyalty Rewards tab */}
                                  {clientSubTab === 'rewards' && (
                                    <div className="space-y-2 flex-1 flex flex-col justify-between">
                                      <div className="space-y-2">
                                        {/* Active tracking service card */}
                                        <div className="bg-zinc-950 p-2.5 rounded border border-zinc-850 space-y-2">
                                          <p className="text-[9px] text-zinc-400 uppercase tracking-widest font-bold">Resgate de Benefícios</p>
                                          
                                          {/* Action button inside phone to claim loyalty */}
                                          <div className="space-y-1.5 pt-1">
                                            <button
                                              onClick={() => {
                                                handleAddLoyaltyPoints('usr-client-1', 100);
                                                setMobileLoyaltyAdded(true);
                                                setTimeout(() => setMobileLoyaltyAdded(false), 2000);
                                              }}
                                              className="w-full bg-zinc-900 hover:bg-zinc-850 text-white font-bold text-[9px] py-1.5 rounded transition-all flex items-center justify-center gap-1 border border-zinc-800 cursor-pointer h-[32px]"
                                            >
                                              <Award className="w-3.5 h-3.5 text-brand-orange" />
                                              {mobileLoyaltyAdded ? "Adicionados +100 Pontos!" : "Simular Geração de Pontos"}
                                            </button>
                                          </div>
                                        </div>

                                        {/* Reserve Bike Request panel */}
                                        <div className="bg-zinc-950 p-2.5 rounded border border-zinc-850 space-y-1 text-center">
                                          <span className="text-[9px] text-zinc-400 uppercase font-black tracking-widest block mb-1">Moto Reserva Disponível</span>
                                          <p className="text-[8.5px] text-zinc-500 mb-1.5">Clientes B2C com mais de 500 pontos acumulam direito à moto reserva gratuita durante manutenção</p>
                                          
                                          <button
                                            disabled={ (loyalty.find(l => l.client_id === 'usr-client-1')?.points_balance || 150) < 500 }
                                            className="w-full bg-brand-orange text-black disabled:bg-zinc-850 disabled:text-zinc-600 font-extrabold text-[9px] py-1.5 rounded transition-all uppercase h-[32px] cursor-pointer"
                                          >
                                            {(loyalty.find(l => l.client_id === 'usr-client-1')?.points_balance || 150) >= 500 ? "Resgatar Moto Reserva" : "Bloqueado (Mínimo 500 pts)"}
                                          </button>
                                        </div>
                                      </div>

                                      <div className="text-[8.5px] text-zinc-400 text-center leading-normal">
                                        Integrado via autenticação Supabase, salvando o JWT token localmente.
                                      </div>
                                    </div>
                                  )}
                                </div>
                              </div>
                            )}

                            {/* SCREEN CONTENT: b2b (Frotistas) */}
                            {mobileScreen === 'b2b' && (
                              <div className="space-y-2.5 flex-1 flex flex-col justify-between">
                                <div className="space-y-2 flex-1 flex flex-col overflow-y-auto">
                                  {/* B2B Header Card */}
                                  <div className="bg-zinc-950 p-2 rounded-xl border border-zinc-850/60 flex justify-between items-center">
                                    <div>
                                      <p className="text-[8px] text-amber-400 uppercase tracking-widest font-black">Hub Central de Inteligência</p>
                                      <p className="text-white text-xs font-black">RápidoSP Logística B2B</p>
                                    </div>
                                    <div className="bg-amber-400 text-zinc-950 text-[8px] px-1.5 py-0.5 rounded-full font-black uppercase">
                                      Gestão Ativa
                                    </div>
                                  </div>

                                  {/* Three high-contrast KPI Cards */}
                                  <div className="grid grid-cols-3 gap-1 bg-zinc-950 p-1.5 rounded-xl border border-zinc-900 text-center">
                                    <div className="border-r border-zinc-900 last:border-0 pr-0.5">
                                      <p className="text-[6px] text-zinc-500 uppercase font-bold leading-none">T.M.A. Médio</p>
                                      <p className="text-[10px] font-black text-white mt-1">18 min</p>
                                    </div>
                                    <div className="border-r border-zinc-900 last:border-0 px-0.5">
                                      <p className="text-[6px] text-zinc-500 uppercase font-bold leading-none">SLA Cumprido</p>
                                      <p className="text-[10px] font-black text-emerald-400 mt-1">98.2%</p>
                                    </div>
                                    <div className="last:border-0 pl-0.5">
                                      <p className="text-[6px] text-zinc-500 uppercase font-bold leading-none flex items-center justify-center gap-0.5">
                                        <span className="w-1 h-1 rounded-full bg-emerald-500 animate-pulse"></span>
                                        Vans Ativas
                                      </p>
                                      <p className="text-[10px] font-black text-white mt-1">4 / 4</p>
                                    </div>
                                  </div>

                                  {/* Hub Map & Traffic Alert Row */}
                                  <div className="space-y-1.5">
                                    <span className="text-[8px] text-zinc-400 font-bold uppercase tracking-wider block">Monitoramento de Rota & Trânsito</span>
                                    
                                    {/* Map + Traffic Feed Grid Layout */}
                                    <div className="grid grid-cols-5 gap-1.5">
                                      {/* Map (3 cols) */}
                                      <div className="col-span-3 bg-zinc-950 rounded-xl relative overflow-hidden border border-zinc-850 h-[85px] shadow-inner flex flex-col justify-end p-1">
                                        <div className="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:10px_10px]"></div>
                                        <svg className="absolute inset-0 w-full h-full text-zinc-900" viewBox="0 0 100 100" preserveAspectRatio="none">
                                          <path d="M 5 30 L 95 30 M 50 5 L 50 95 M 5 70 L 95 70" fill="none" stroke="#27272a" strokeWidth="1.5" />
                                          <path d="M 10 30 L 50 30 L 50 70 L 90 70" fill="none" stroke="#FF5A00" strokeWidth="1.8" strokeLinecap="round" strokeDasharray="2 2" className="animate-pulse" />
                                        </svg>
                                        {/* Hub Center */}
                                        <div className="absolute top-[22%] left-[10%] z-10 text-[7px] bg-zinc-900 border border-zinc-800 px-1 py-0.5 rounded leading-none text-zinc-300">
                                          Hub 🏢
                                        </div>
                                        {/* Moving Yellow Van on Assignment */}
                                        <div className="absolute top-[45%] left-[43%] z-20 text-[10px] animate-bounce">
                                          🚐
                                        </div>
                                        {/* Map Status Indicator */}
                                        <div className="absolute bottom-1 left-1 bg-black/80 px-1.5 py-0.5 rounded text-[5px] font-mono text-zinc-400">
                                          V01 • Rota Carol
                                        </div>
                                      </div>

                                      {/* Mini traffic alert feed (2 cols) */}
                                      <div className="col-span-2 bg-zinc-950 rounded-xl border border-zinc-850 p-1.5 flex flex-col justify-between h-[85px] overflow-hidden">
                                        <p className="text-[6.5px] text-zinc-500 font-extrabold uppercase border-b border-zinc-900 pb-0.5 mb-1 flex items-center gap-0.5 shrink-0">
                                          ⚠️ Trânsito
                                        </p>
                                        <div className="space-y-1 font-mono text-[5px] leading-tight overflow-y-auto flex-1 select-text scrollbar-none">
                                          <p className="text-zinc-400"><strong className="text-amber-400 font-bold">07:42</strong> Paulista lento.</p>
                                          <p className="text-zinc-400"><strong className="text-emerald-400 font-bold">07:55</strong> Van 01 no local.</p>
                                          <p className="text-zinc-400"><strong className="text-amber-400 font-bold">08:02</strong> Chuva S. Sul.</p>
                                        </div>
                                      </div>
                                    </div>
                                  </div>

                                  <div className="space-y-1.5">
                                    <span className="text-[8px] text-zinc-500 font-bold uppercase tracking-wider block">Monitoramento Simultâneo</span>
                                    
                                    {/* Fleet loop list */}
                                    {fleetBikes.map(bike => (
                                      <div
                                        key={bike.id}
                                        onClick={() => setSelectedB2bBikeId(bike.id)}
                                        className={`p-2 rounded border transition-all cursor-pointer space-y-1.5 ${
                                          selectedB2bBikeId === bike.id 
                                            ? 'border-brand-orange bg-zinc-950' 
                                            : 'border-zinc-900 bg-zinc-950/60 hover:bg-zinc-950'
                                        }`}
                                      >
                                        <div className="flex justify-between items-start">
                                          <div>
                                            <p className="text-[9px] font-extrabold text-white">{bike.model}</p>
                                            <p className="text-[8px] font-mono text-zinc-400">Placa: {bike.plate}</p>
                                          </div>
                                          <span className={`text-[7px] font-bold px-1 rounded ${
                                            bike.progress === 100 ? 'bg-emerald-500/10 text-emerald-400' : 'bg-brand-orange-light text-brand-orange'
                                          }`}>
                                            {bike.status}
                                          </span>
                                        </div>

                                        {/* Mini progress bar */}
                                        <div className="space-y-1">
                                          <div className="flex justify-between text-[7px] text-zinc-500">
                                            <span>Mecânico: {bike.mechanic}</span>
                                            <span>{bike.progress}%</span>
                                          </div>
                                          <div className="w-full bg-zinc-900 h-1 rounded-full overflow-hidden">
                                            <div
                                              className="bg-brand-orange h-full rounded-full transition-all duration-500"
                                              style={{ width: `${bike.progress}%` }}
                                            ></div>
                                          </div>
                                        </div>

                                        {/* Expand Details if selected */}
                                        {selectedB2bBikeId === bike.id && (
                                          <div className="pt-2 border-t border-zinc-900 flex justify-between items-center">
                                            <span className="text-[7px] text-zinc-400 font-mono">Setor: {bike.bay}</span>
                                            {bike.camActive ? (
                                              <button
                                                onClick={(e) => {
                                                  e.stopPropagation();
                                                  setIsB2bCamOpen(true);
                                                  addLog(`B2B Monitor: Antônio acessou Câmera IP Ao Vivo da ${bike.bay} para inspecionar placa ${bike.plate}.`, 'info');
                                                }}
                                                className="text-[8px] bg-brand-orange text-black px-1.5 py-0.5 rounded font-black flex items-center gap-0.5"
                                              >
                                                <Video className="w-2.5 h-2.5" /> Ver Câmera IP
                                              </button>
                                            ) : (
                                              <span className="text-[7px] text-zinc-500 italic">Dispensado</span>
                                            )}
                                          </div>
                                        )}
                                      </div>
                                    ))}
                                  </div>
                                </div>

                                {/* Fleet Cam Overlay modal inside phone screen */}
                                {isB2bCamOpen && (
                                  <div className="absolute inset-x-4 top-24 bg-zinc-950 border border-brand-orange/30 rounded p-2 z-50 space-y-2 shadow-2xl">
                                    <div className="flex justify-between items-center text-[8px] border-b border-zinc-900 pb-1">
                                      <span className="text-white font-extrabold flex items-center gap-1">
                                        <Video className="w-3 h-3 text-brand-orange animate-pulse" />
                                        Feed Frotista: {fleetBikes.find(b => b.id === selectedB2bBikeId)?.plate}
                                      </span>
                                      <button onClick={() => setIsB2bCamOpen(false)} className="text-zinc-400 hover:text-white">
                                        <X className="w-3.5 h-3.5" />
                                      </button>
                                    </div>

                                    {/* Mini Camera Stream inside popup */}
                                    <div className="relative aspect-video bg-black rounded overflow-hidden flex flex-col justify-between p-1">
                                      <div className="text-[6px] text-white font-mono z-10 flex justify-between bg-black/40 px-0.5 rounded">
                                        <span>REC Ao Vivo • {fleetBikes.find(b => b.id === selectedB2bBikeId)?.bay}</span>
                                        <span>30 FPS</span>
                                      </div>
                                      <div className="absolute inset-0 flex items-center justify-center pointer-events-none opacity-50">
                                        <svg viewBox="0 0 100 100" className="w-12 h-12 text-zinc-700 animate-spin" style={{ animationDuration: '6s' }}>
                                          <circle cx="50" cy="50" r="30" stroke="currentColor" strokeWidth="2" strokeDasharray="6 3" fill="none" />
                                        </svg>
                                      </div>
                                      <div className="text-[6.5px] text-emerald-400 font-mono z-10 bg-black/50 px-0.5 rounded flex justify-between">
                                        <span>Placa: {fleetBikes.find(b => b.id === selectedB2bBikeId)?.plate}</span>
                                        <span>WebSocket Conectado</span>
                                      </div>
                                    </div>
                                    <p className="text-[7.5px] text-zinc-400 leading-tight">
                                      Câmera IP vinculada à baia via Supabase Realtime para acompanhamento transparente do Antônio.
                                    </p>
                                  </div>
                                )}

                                {/* B2B Bulk Maintenance Action Button */}
                                <button
                                  onClick={() => {
                                    setFleetBikes(prev => prev.map(b => b.progress < 100 ? { ...b, progress: Math.min(100, b.progress + 15), status: 'Em progresso' } : b));
                                    addLog("B2B Frota: Simulação de avanço simultâneo de manutenção para otimização de frotas executada.", "success");
                                  }}
                                  className="w-full bg-emerald-500 hover:bg-emerald-600 text-black font-extrabold text-[9px] py-1.5 rounded cursor-pointer uppercase text-center flex items-center justify-center gap-1"
                                >
                                  <Users className="w-3.5 h-3.5" />
                                  Otimizar Frota (Acelerar Manutenção)
                                </button>
                              </div>
                            )}

                          </div>

                          {/* Home indicator bar inside Phone screen */}
                          <div className="bg-zinc-950 py-1.5 flex justify-center z-30 shrink-0">
                            <div className="w-24 h-1 bg-zinc-700 rounded-full"></div>
                          </div>
                        </div>

                      </div>
                    </div>
                  </div>
                </motion.div>
              )}
            </AnimatePresence>

          </div>

          {/* Right sidebar - Administrative Roles and Assets overview (Spans 4 cols) */}
          {currentTab !== 'landing' && (
            <div className="lg:col-span-4 space-y-6">
              
              {/* Commercial Profiles Explainer */}
              <div className="bg-zinc-900 border border-zinc-800 rounded-xl p-4 shadow-sm space-y-3">
                <h4 className="font-bold text-white text-sm flex items-center gap-1.5">
                  <ShieldCheck className="w-4 h-4 text-brand-orange" />
                  Controle de Perfis Operacionais
                </h4>
                <p className="text-xs text-zinc-400 leading-normal">
                  Estrutura de acessos e permissões para garantir a máxima segurança, agilidade e privacidade das operações:
                </p>

                <div className="space-y-2 mt-2">
                  <div className="p-2.5 bg-zinc-950 rounded border border-zinc-850 text-xs">
                    <div className="flex justify-between items-center mb-1">
                      <strong className="text-white">Cliente Particular (B2C)</strong>
                      <span className="text-[9px] bg-zinc-800 text-zinc-400 font-mono px-1.5 py-0.5 rounded">Carol & Carlos</span>
                    </div>
                    <p className="text-[11px] text-zinc-500 leading-normal">Agendam manutenções rápidas, acompanham a van em tempo real e acumulam pontos de fidelidade.</p>
                  </div>

                  <div className="p-2.5 bg-zinc-950 rounded border border-zinc-850 text-xs">
                    <div className="flex justify-between items-center mb-1">
                      <strong className="text-white">Gestor de Frota (B2B)</strong>
                      <span className="text-[9px] bg-zinc-800 text-zinc-400 font-mono px-1.5 py-0.5 rounded">Frotistas (Ex: Antônio)</span>
                    </div>
                    <p className="text-[11px] text-zinc-500 leading-normal">Monitoram simultaneamente múltiplas motocicletas corporativas e acessam feeds IP ao vivo.</p>
                  </div>

                  <div className="p-2.5 bg-zinc-950 rounded border border-zinc-850 text-xs">
                    <div className="flex justify-between items-center mb-1">
                      <strong className="text-white">Mecânico do Furgão</strong>
                      <span className="text-[9px] bg-zinc-805 text-zinc-350 font-mono px-1.5 py-0.5 rounded">Danilo Mecânico</span>
                    </div>
                    <p className="text-[11px] text-zinc-500 leading-normal">Aceitam chamados via GPS, realizam vistorias de segurança e executam os checklists na van volante.</p>
                  </div>

                  <div className="p-2.5 bg-zinc-950 rounded border border-zinc-850 text-xs">
                    <div className="flex justify-between items-center mb-1">
                      <strong className="text-white">Administrador Central</strong>
                      <span className="text-[9px] bg-brand-orange-light text-brand-orange font-mono px-1.5 py-0.5 rounded border border-brand-orange/20">Isabela Adm</span>
                    </div>
                    <p className="text-[11px] text-zinc-500 leading-normal">Supervisão irrestrita do fluxo operacional, liberação de novos furgões e auditoria de qualidade global.</p>
                  </div>
                </div>
              </div>

              {/* Commercial Assets Counter */}
              <div className="bg-zinc-900 border border-zinc-800 rounded-xl p-4 shadow-sm space-y-3">
                <h4 className="font-bold text-white text-sm flex items-center gap-1.5">
                  <Database className="w-4 h-4 text-emerald-400" />
                  Painel Geral de Ativos Operacionais
                </h4>
                <p className="text-xs text-zinc-400 leading-normal">
                  Indicadores de integridade e volume de dados ativos no sistema central da OttoMotos:
                </p>

                <div className="space-y-2 text-xs">
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Usuários Cadastrados</span>
                    <span className="font-bold text-white">{users.length} perfis</span>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Serviços no Catálogo</span>
                    <span className="font-bold text-white">{services.length} ativos</span>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Ordens de Serviço (O.S.)</span>
                    <span className="font-bold text-white">{orders.length} registradas</span>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Estoque de Peças (Vans)</span>
                    <span className="font-bold text-white">{inventory.length} itens</span>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Pontuação de Fidelidade</span>
                    <span className="font-bold text-white">{loyalty.length} contas</span>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-zinc-950 rounded border border-zinc-850">
                    <span className="font-mono text-zinc-400">Checklists de Qualidade</span>
                    <span className="font-bold text-white">{validations.length} vistorias</span>
                  </div>
                </div>

                <button
                  onClick={() => {
                    setUsers(INITIAL_USERS);
                    setServices(INITIAL_SERVICES);
                    setOrders(INITIAL_ORDERS);
                    setInventory(INITIAL_INVENTORY);
                    setLoyalty(INITIAL_LOYALTY);
                    setValidations(INITIAL_VALIDATIONS);
                    addLog('Todos os registros operacionais foram reiniciados para o padrão comercial.', 'info');
                  }}
                  className="w-full mt-2 bg-zinc-950 hover:bg-zinc-850 text-zinc-400 hover:text-white border border-zinc-800 text-[11px] py-1.5 rounded transition-all flex items-center justify-center gap-1 cursor-pointer"
                >
                  <RefreshCw className="w-3 h-3" /> Restaurar Registros Padrão
                </button>
              </div>

              {/* Quality validation tag */}
              <div className="p-3 bg-zinc-900/40 border border-zinc-850 rounded-lg text-xs leading-relaxed text-zinc-400">
                <span className="font-bold text-zinc-200 block mb-1">Selo de Agilidade & Confiança</span>
                Esta central permite validar a integridade dos atendimentos em tempo real, conectando com precisão os furgões de rua com a retaguarda administrativa.
              </div>

            </div>
          )}

        </div>

      </main>

      <footer className="border-t border-zinc-900 bg-zinc-950 py-8 px-4 text-center text-xs text-zinc-500 mt-12">
        <p>© 2026 OttoMotos Tecnologia em Reparos Rápidos de Motocicletas. Todos os direitos reservados.</p>
        <p className="mt-1 text-zinc-650">Desenvolvido sob rígidos padrões de transparência, agilidade de atendimento e controle de frotas.</p>
      </footer>
    </div>
  );
}
